<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Find a Caterer | Caterus</title>
  <meta name="description" content="Browse and filter hundreds of vetted caterers across Melbourne. Filter by occasion, cuisine, guests, and price."/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/styles.css"/>
  <style>
    .cl-wrap { display:grid; grid-template-columns:280px 1fr; gap:32px; align-items:start; padding:40px 0 80px; }
    .cl-filters { position:sticky; top:24px; background:var(--surface,#faf9f6); border:1px solid rgba(0,0,0,0.08); border-radius:16px; padding:24px; }
    .cl-filters h3 { font-size:0.78rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-soft,#6b6b6b); margin:20px 0 10px; }
    .cl-filters h3:first-child { margin-top:0; }
    .cl-fi { display:flex; flex-direction:column; gap:8px; }
    .cl-fi label { display:flex; align-items:center; gap:8px; font-size:0.9rem; cursor:pointer; }
    .cl-fi input[type=checkbox] { width:16px; height:16px; accent-color:#75896d; cursor:pointer; }
    .cl-input { width:100%; padding:9px 12px; border:1px solid var(--line,#e0dbd2); border-radius:8px; font-size:0.9rem; font-family:inherit; background:transparent; color:inherit; }
    .cl-input:focus { outline:none; border-color:#75896d; }
    .cl-range { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .cl-apply { width:100%; margin-top:20px; padding:10px; background:#75896d; color:#fff; border:none; border-radius:10px; font-size:0.9rem; font-weight:600; cursor:pointer; font-family:inherit; }
    .cl-apply:hover { background:#627a5c; }
    .cl-reset { width:100%; margin-top:8px; padding:8px; background:transparent; border:1px solid var(--line,#e0dbd2); border-radius:10px; font-size:0.85rem; cursor:pointer; font-family:inherit; color:var(--ink-soft,#666); }
    .cl-reset:hover { background:var(--surface,#f5f2ee); }
    .cl-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px; }
    .cl-count { font-size:0.88rem; color:var(--ink-soft,#666); }
    .cl-sort { display:flex; align-items:center; gap:8px; font-size:0.88rem; }
    .cl-sort select { padding:6px 10px; border:1px solid var(--line,#e0dbd2); border-radius:8px; font-size:0.88rem; font-family:inherit; background:transparent; cursor:pointer; }
    .cl-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:24px; }
    .cl-card { background:var(--surface,#faf9f6); border:1px solid rgba(0,0,0,0.07); border-radius:16px; overflow:hidden; transition:transform 0.2s,box-shadow 0.2s; text-decoration:none; color:inherit; display:block; }
    .cl-card:hover { transform:translateY(-3px); box-shadow:0 12px 32px rgba(0,0,0,0.1); }
    .cl-card__img { aspect-ratio:16/9; overflow:hidden; background:#e8e4dc; }
    .cl-card__img img { width:100%; height:100%; object-fit:cover; display:block; }
    .cl-card__body { padding:16px; }
    .cl-card__name { font-weight:700; font-size:1rem; margin-bottom:4px; }
    .cl-card__meta { font-size:0.82rem; color:var(--ink-soft,#666); margin-bottom:8px; display:flex; gap:10px; flex-wrap:wrap; }
    .cl-card__tags { display:flex; gap:6px; flex-wrap:wrap; }
    .cl-card__tag { font-size:0.74rem; background:var(--accent-soft,#eef0eb); color:#5a6e52; padding:3px 8px; border-radius:100px; }
    .cl-card__price { font-weight:700; color:#75896d; font-size:0.9rem; }
    .cl-card__rating { display:flex; align-items:center; gap:4px; font-size:0.82rem; }
    .cl-star { color:#e8a838; }
    .cl-empty { text-align:center; padding:60px 20px; color:var(--ink-soft,#666); }
    .cl-pagination { display:flex; justify-content:center; gap:8px; margin-top:40px; flex-wrap:wrap; }
    .cl-pagination a, .cl-pagination span { display:inline-flex; align-items:center; justify-content:center; width:38px; height:38px; border-radius:8px; font-size:0.88rem; font-weight:600; text-decoration:none; border:1px solid var(--line,#e0dbd2); }
    .cl-pagination a { color:inherit; } .cl-pagination a:hover { background:var(--accent-soft,#eef0eb); }
    .cl-pagination span { background:#75896d; color:#fff; border-color:#75896d; }
    .cl-active-filters { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
    .cl-af { display:inline-flex; align-items:center; gap:5px; font-size:0.8rem; background:#eef0eb; color:#5a6e52; padding:4px 10px; border-radius:100px; }
    @media (max-width:768px) {
      .cl-wrap { grid-template-columns:1fr; }
      .cl-filters { position:static; }
    }
  </style>
</head>
<body>
  <div class="noise" aria-hidden="true"></div>

  <!-- NAV -->
  <header class="nav" id="nav">
    <div class="nav__inner">
      <a href="/" class="logo" aria-label="Caterus home"><% if (siteLogo) { %><img src="/<%= siteLogo %>" alt="Caterus" style="height:44px;width:auto;object-fit:contain;display:block;max-width:180px"><% } else { %><span class="logo__dot" aria-hidden="true"></span>Caterus<% } %></a>
      <nav class="nav__links" aria-label="Primary">
        <a href="/#how-it-works">How it works</a>
        <a href="/caterers">Caterers</a>
        <a href="/#occasions">Occasions</a>
        <a href="/#for-caterers">For caterers</a>
      </nav>
      <div class="nav__end">
        <a href="/#search" class="btn btn--fill">Find a caterer</a>
      </div>
      <button class="nav__ham" id="ham" aria-label="Open menu" aria-expanded="false"><span></span><span></span></button>
    </div>
    <div class="nav__mob" id="mob" hidden>
      <a href="/#how-it-works">How it works</a>
      <a href="/caterers">Caterers</a>
      <a href="/#occasions">Occasions</a>
      <a href="/#for-caterers">For caterers</a>
      <a href="/#search" class="btn btn--fill">Find a caterer</a>
    </div>
  </header>

  <main>
    <div class="container">
      <div style="padding:36px 0 0">
        <h1 style="font-size:2rem;font-weight:800;margin-bottom:8px">Find a Caterer</h1>
        <p style="color:var(--ink-soft,#666);margin-bottom:0">Vetted catering companies and independent chefs across Melbourne.</p>
      </div>

      <!-- Active filter chips -->
      <% const hasFilters = query.occasion || query.suburb || query.cuisine || query.guests || query.max_price; %>
      <% if (hasFilters) { %>
      <div class="cl-active-filters" style="margin-top:16px">
        <% if (query.occasion) { %><span class="cl-af">Occasion: <%= query.occasion %></span><% } %>
        <% if (query.suburb) { %><span class="cl-af">Suburb: <%= query.suburb %></span><% } %>
        <% if (query.cuisine) { %><span class="cl-af">Cuisine: <%= query.cuisine %></span><% } %>
        <% if (query.guests) { %><span class="cl-af">Min guests: <%= query.guests %>+</span><% } %>
        <% if (query.max_price) { %><span class="cl-af">Max $<%= query.max_price %>/pp</span><% } %>
        <a href="/caterers" style="font-size:0.8rem;color:#999;text-decoration:underline;align-self:center;margin-left:4px">Clear all</a>
      </div>
      <% } %>

      <div class="cl-wrap">

        <!-- Filters sidebar -->
        <aside class="cl-filters">
          <form id="filter-form" method="GET" action="/caterers">

            <h3>Occasion</h3>
            <div class="cl-fi">
              <% const occasions = ['corporate','wedding','party','private dining','gala dinner','conference','christmas','birthday','baby shower','graduation']; %>
              <% occasions.forEach(function(occ) { %>
              <label>
                <input type="checkbox" name="occasion" value="<%= occ %>" <%=query.occasion===occ?'checked':''%>>
                <%= occ.charAt(0).toUpperCase() + occ.slice(1) %>
              </label>
              <% }) %>
            </div>

            <h3>Location</h3>
            <input type="text" name="suburb" class="cl-input" placeholder="e.g. Richmond, CBD" value="<%= query.suburb || '' %>">

            <h3>Cuisine</h3>
            <input type="text" name="cuisine" class="cl-input" placeholder="e.g. Italian, Asian Fusion" value="<%= query.cuisine || '' %>">

            <h3>Guest Count</h3>
            <select name="guests" class="cl-input">
              <option value="">Any size</option>
              <option value="10"  <%=query.guests==='10' ?'selected':''%>>10+ guests</option>
              <option value="20"  <%=query.guests==='20' ?'selected':''%>>20+ guests</option>
              <option value="50"  <%=query.guests==='50' ?'selected':''%>>50+ guests</option>
              <option value="100" <%=query.guests==='100'?'selected':''%>>100+ guests</option>
              <option value="200" <%=query.guests==='200'?'selected':''%>>200+ guests</option>
              <option value="500" <%=query.guests==='500'?'selected':''%>>500+ guests</option>
            </select>

            <h3>Max Price (per person)</h3>
            <select name="max_price" class="cl-input">
              <option value="">Any price</option>
              <option value="30"  <%=query.max_price==='30' ?'selected':''%>>Up to $30</option>
              <option value="50"  <%=query.max_price==='50' ?'selected':''%>>Up to $50</option>
              <option value="80"  <%=query.max_price==='80' ?'selected':''%>>Up to $80</option>
              <option value="100" <%=query.max_price==='100'?'selected':''%>>Up to $100</option>
              <option value="150" <%=query.max_price==='150'?'selected':''%>>Up to $150</option>
              <option value="200" <%=query.max_price==='200'?'selected':''%>>Up to $200</option>
            </select>

            <input type="hidden" name="sort" id="sort-hidden" value="<%= query.sort || '' %>">

            <button type="submit" class="cl-apply">Apply Filters</button>
            <button type="button" class="cl-reset" onclick="window.location='/caterers'">Reset</button>
          </form>
        </aside>

        <!-- Results -->
        <div>
          <div class="cl-head">
            <p class="cl-count"><strong><%= total %></strong> caterer<%= total !== 1 ? 's' : '' %> found</p>
            <div class="cl-sort">
              <label for="sort-sel" style="color:var(--ink-soft,#666)">Sort by</label>
              <select id="sort-sel" class="cl-input" style="width:auto" onchange="document.getElementById('sort-hidden').value=this.value;document.getElementById('filter-form').submit()">
                <option value=""         <%=!query.sort                  ?'selected':''%>>Featured</option>
                <option value="rating"   <%=query.sort==='rating'        ?'selected':''%>>Highest rated</option>
                <option value="price_asc" <%=query.sort==='price_asc'   ?'selected':''%>>Price: low to high</option>
                <option value="price_desc" <%=query.sort==='price_desc' ?'selected':''%>>Price: high to low</option>
                <option value="reviews"  <%=query.sort==='reviews'       ?'selected':''%>>Most reviewed</option>
                <option value="newest"   <%=query.sort==='newest'        ?'selected':''%>>Newest</option>
              </select>
            </div>
          </div>

          <% if (caterers.length === 0) { %>
          <div class="cl-empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.3;margin-bottom:16px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <p style="font-size:1.1rem;font-weight:600;margin-bottom:8px">No caterers found</p>
            <p style="font-size:0.9rem">Try adjusting your filters or <a href="/caterers" style="color:#75896d">browse all caterers</a>.</p>
          </div>
          <% } else { %>
          <div class="cl-grid">
            <% caterers.forEach(function(cat) {
                 var img = cat.featured_image ? '/' + cat.featured_image : '/assets/food1.png';
                 var rating = parseFloat(cat.rating_avg || 0).toFixed(1);
                 var price = cat.price_from ? formatCurrency(cat.price_from) + '/pp' : '';
            %>
            <a href="/caterer/<%= cat.slug %>" class="cl-card">
              <div class="cl-card__img">
                <img src="<%= img %>" alt="<%= cat.business_name %>" loading="lazy">
              </div>
              <div class="cl-card__body">
                <p class="cl-card__name"><%= cat.business_name %></p>
                <div class="cl-card__meta">
                  <% if (cat.suburb) { %><span><%= cat.suburb %></span><% } %>
                  <% if (cat.cuisine_type) { %><span><%= cat.cuisine_type %></span><% } %>
                </div>
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                  <% if (parseFloat(cat.rating_avg) > 0) { %>
                  <span class="cl-card__rating"><span class="cl-star">&#9733;</span> <%= rating %> <span style="color:#999">(<%= cat.review_count || 0 %>)</span></span>
                  <% } else { %><span></span><% } %>
                  <% if (price) { %><span class="cl-card__price">from <%= price %></span><% } %>
                </div>
                <% if (cat.tags && cat.tags.length) { %>
                <div class="cl-card__tags">
                  <% cat.tags.slice(0,3).forEach(function(t) { %><span class="cl-card__tag"><%= t %></span><% }) %>
                </div>
                <% } %>
              </div>
            </a>
            <% }) %>
          </div>

          <!-- Pagination -->
          <% if (totalPages > 1) { %>
          <div class="cl-pagination">
            <% if (page > 1) { %>
            <a href="?<%= new URLSearchParams({...query, page: page-1}).toString() %>">&lsaquo;</a>
            <% } %>
            <% for (var p = Math.max(1,page-2); p <= Math.min(totalPages,page+2); p++) { %>
              <% if (p === page) { %><span><%= p %></span>
              <% } else { %><a href="?<%= new URLSearchParams({...query, page: p}).toString() %>"><%= p %></a><% } %>
            <% } %>
            <% if (page < totalPages) { %>
            <a href="?<%= new URLSearchParams({...query, page: page+1}).toString() %>">&rsaquo;</a>
            <% } %>
          </div>
          <% } %>
          <% } %>
        </div>

      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer__inner">
      <a href="/" class="logo footer__logo" aria-label="Caterus"><% if (siteLogo) { %><img src="/<%= siteLogo %>" alt="Caterus" style="height:44px;width:auto;object-fit:contain;display:block;max-width:180px"><% } else { %><span class="logo__dot"></span> Caterus<% } %></a>
      <nav class="footer__links" aria-label="Footer">
        <a href="/#how-it-works">How it works</a>
        <a href="/caterers">Caterers</a>
        <a href="/#occasions">Occasions</a>
        <a href="/#for-caterers">For caterers</a>
      </nav>
      <% if (socialLinks && socialLinks.length) { %>
      <div class="footer__socials">
        <% socialLinks.forEach(function(s) { if (!SOCIAL_ICONS[s.platform]) return; %><a href="<%= s.url %>" aria-label="<%= s.platform %>" target="_blank" rel="noopener"><%- SOCIAL_ICONS[s.platform] %></a><% }) %>
      </div>
      <% } %>
    </div>
    <div class="container footer__bottom">
      <p>&copy; <%= new Date().getFullYear() %> <%= footerTagline %></p>
      <p>Payments powered by <strong>Stripe</strong></p>
    </div>
  </footer>

  <script src="/script.js?v=4"></script>
</body>
</html>
