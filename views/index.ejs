  <div class="modal" id="register-modal" aria-hidden="true">
    <div class="modal__backdrop" data-modal-close></div>
    <div class="modal__dialog" role="dialog" aria-modal="true" aria-labelledby="register-title" data-lenis-prevent>
      <button type="button" class="modal__close" data-modal-close aria-label="Close registration form">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <p class="section-label">Become a partner</p>
      <h2 id="register-title" class="h-display">List your catering business.</h2>
      <p class="modal__lede">Free to join - reach thousands of event planners and only pay a commission when you get booked.</p>

      <form class="cform" id="register-form" novalidate>
        <label>Business name<input type="text" name="business" placeholder="Olive &amp; Vine Catering" required/></label>
        <div class="cform__row">
          <label>Your name<input type="text" name="contactName" placeholder="Jane Doe" autocomplete="name" required/></label>
          <label>Email<input type="email" name="email" placeholder="jane@oliveandvine.com.au" autocomplete="email" required/></label>
        </div>
        <label>Phone<div class="fe-phone-wrap" style="display:flex;gap:6px"><%- include('partials/fe-phone-picker', { currentCountry: '+61', placeholder: '0412 345 678', inputId: 'rf-phone' }) %></div></label>
        <label>Cuisine
          <select name="cuisine">
            <option value="">Select…</option>
            <option>Modern Australian</option>
            <option>Mediterranean</option>
            <option>Italian</option>
            <option>Asian Fusion</option>
            <option>BBQ &amp; Grill</option>
            <option>Fine Dining</option>
            <option>Other</option>
          </select>
