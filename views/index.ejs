        <label>Primary service area <span class="cform__opt">(optional)</span><input type="text" name="area" placeholder="e.g. Melbourne CBD &amp; inner suburbs"/></label>
        <% if (captchaType === 'recaptcha_v2' || captchaType === 'hcaptcha') { %>
        <div id="captcha-register" data-captcha-widget style="margin-bottom:12px"></div>
        <% } %>
        <button type="submit" class="btn btn--fill">Submit application</button>
      </form>
