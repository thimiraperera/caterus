<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Caterus - Find &amp; Book Melbourne's Best Caterers</title>
  <meta name="description" content="Caterus is Australia's trusted catering marketplace. Search, compare and book vetted catering companies and independent chefs for any event. Secure payments, instant confirmation."/>
  <meta property="og:title" content="Caterus - Australia's Catering Marketplace"/>
  <meta property="og:description" content="Find and book vetted caterers for corporate events, weddings, parties and more."/>
  <meta property="og:type" content="website"/>
  <link rel="canonical" href="https://www.caterus.com.au/"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/styles.css"/>
  <% if (typeof siteFavicon !== 'undefined' && siteFavicon) { %><link rel="icon" href="/<%= siteFavicon %>"><% } %>
  <% if (typeof faqs !== 'undefined' && faqs.length > 0) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": <%- JSON.stringify(faqs.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))) %>
  }
  </script>
  <% } %>
</head>
<body>
  <div class="noise" aria-hidden="true"></div>

  <!-- ============ NAV ============ -->
  <header class="nav" id="nav">
    <div class="nav__inner">
      <a href="#top" class="logo" aria-label="Caterus home"><% if (siteLogo) { %><img src="/<%= siteLogo %>" alt="Caterus" style="height:44px;width:auto;object-fit:contain;display:block;max-width:180px"><% } else { %><span class="logo__dot" aria-hidden="true"></span>Caterus<% } %></a>

      <nav class="nav__links" aria-label="Primary">
        <a href="#how-it-works">How it works</a>
        <a href="#caterers">Caterers</a>
        <a href="#occasions">Occasions</a>
        <a href="#for-caterers">For caterers</a>
      </nav>

      <div class="nav__end">
        <a href="#" class="nav__contact" data-contact-open>Contact</a>
        <a href="/caterers" class="btn btn--fill">Find a caterer</a>
      </div>

      <button class="nav__ham" id="ham" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>

    <div class="nav__mob" id="mob" hidden>
      <a href="#how-it-works">How it works</a>
      <a href="#caterers">Caterers</a>
      <a href="#occasions">Occasions</a>
      <a href="#for-caterers">For caterers</a>
      <a href="#" class="nav__contact" data-contact-open>Contact</a>
      <a href="/caterers" class="btn btn--fill">Find a caterer</a>
    </div>
  </header>

  <main id="top">

  <!-- ============ HERO ============ -->
  <section class="hero" id="search">
    <div class="hero__orbs" aria-hidden="true"><span></span><span></span><span></span></div>
    <div class="hero__inner container">
      <p class="kicker">
        <span class="kicker__line"></span>
        <svg class="kicker__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7a2 2 0 0 0 2 2 2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>
        <span class="kicker__txt">Australia's catering marketplace</span>
        <span class="kicker__line"></span>
      </p>

      <h1 class="hero__h1">Find the <span class="hl">perfect caterer</span> for any event.</h1>

      <p class="hero__body">Search hundreds of vetted catering companies and independent chefs across Melbourne. Book securely in minutes.</p>

      <!-- Search form -->
      <form class="search" id="search-form" role="search" novalidate>
        <div class="search__field" style="position:relative">
          <label for="s-loc">Suburb</label>
          <input id="s-loc" type="text" placeholder="e.g. Melbourne CBD" autocomplete="off"/>
          <ul id="s-loc-suggestions" style="position:absolute;top:100%;left:0;right:0;z-index:200;background:#fff;border:1px solid #e0dbd2;border-top:none;border-radius:0 0 8px 8px;max-height:200px;overflow-y:auto;margin:0;padding:0;list-style:none;box-shadow:0 8px 20px rgba(0,0,0,.1);display:none"></ul>
        </div>
        <div class="search__field">
          <label for="s-occ">Occasion</label>
          <select id="s-occ" aria-label="Occasion">
            <option value="">Any occasion</option>
            <% (occasions || []).forEach(function(occ) { %>
            <option value="<%= occ.toLowerCase() %>"><%= occ %></option>
            <% }) %>
          </select>
        </div>
        <div class="search__field">
          <label for="s-guests">Guests</label>
          <select id="s-guests" aria-label="Number of guests">
            <option value="">Any size</option>
            <option value="1">1 - 20</option>
            <option value="21">21 - 50</option>
            <option value="51">51 - 100</option>
            <option value="101">101 - 250</option>
            <option value="251">250+</option>
          </select>
        </div>
        <button class="btn btn--fill search__go" type="submit" id="go-btn">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Search
        </button>
      </form>

      <div class="hero__proof">
        <div class="faces" aria-label="Recent Caterus customers">
          <span><img src="/assets/avatars/avatar-sr.webp" alt="SR" width="34" height="34"></span>
          <span><img src="/assets/avatars/avatar-mk.webp" alt="MK" width="34" height="34"></span>
          <span><img src="/assets/avatars/avatar-jp.webp" alt="JP" width="34" height="34"></span>
          <span><img src="/assets/avatars/avatar-al.webp" alt="AL" width="34" height="34"></span>
        </div>
        <p><span class="stars">★★★★★</span> Trusted by <strong class="count" data-count="<%= stats.totalEvents %>" data-suffix="+">0</strong> event planners</p>
      </div>

      <button type="button" class="hero__caterer" data-register-open>
        <span class="hero__caterer-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/></svg></span>
        <span class="hero__caterer-txt">Run a catering business? <strong>List it free</strong></span>
        <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
      </button>
    </div>

    <!-- Full-bleed hero strip -->
    <div class="hero__media container">
      <figure class="hero__shot hero__shot--big">
        <img src="/assets/hero_main.png" alt="Premium catering spread" fetchpriority="high"/>
        <figcaption><span class="tick"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> <%= stats.totalCaterers %>+ vetted caterers available</figcaption>
      </figure>
      <figure class="hero__shot">
        <img src="/assets/catering_spread.png" alt="Grazing table" loading="lazy"/>
        <figcaption>4.9 ★ · 2,400+ reviews</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ DOUBLE MARQUEE STRIP ============ -->
  <div class="marquee2" aria-hidden="true">
    <div class="mq-strip mq-strip--a">
      <div class="mq-track">
        <span>Corporate Events</span><i>·</i><span>Weddings</span><i>·</i><span>Gala Dinners</span>
        <svg class="mq-ico" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 18h18"/><path d="M4.5 18a7.5 7.5 0 0 1 15 0"/><path d="M12 7.5V6"/><circle cx="12" cy="5" r="1"/></svg>
        <span>Birthday Parties</span><i>·</i><span>Product Launches</span><i>·</i><span>Private Dining</span><i>·</i><span>Conferences</span><i>·</i><span>Christmas Parties</span><i>·</i>
        <span>Corporate Events</span><i>·</i><span>Weddings</span><i>·</i><span>Gala Dinners</span>
        <svg class="mq-ico" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 18h18"/><path d="M4.5 18a7.5 7.5 0 0 1 15 0"/><path d="M12 7.5V6"/><circle cx="12" cy="5" r="1"/></svg>
        <span>Birthday Parties</span><i>·</i><span>Product Launches</span><i>·</i><span>Private Dining</span><i>·</i><span>Conferences</span><i>·</i><span>Christmas Parties</span><i>·</i>
      </div>
    </div>
    <div class="mq-strip mq-strip--b">
      <div class="mq-track mq-track--rev">
        <span>Mediterranean</span><i>·</i><span>Italian</span><i>·</i><span>BBQ &amp; Grill</span>
        <svg class="mq-ico" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 18h18"/><path d="M4.5 18a7.5 7.5 0 0 1 15 0"/><path d="M12 7.5V6"/><circle cx="12" cy="5" r="1"/></svg>
        <span>Asian Fusion</span><i>·</i><span>Fine Dining</span><i>·</i><span>Grazing Tables</span><i>·</i><span>Canapés</span><i>·</i><span>Wood-fired Pizza</span><i>·</i>
        <span>Mediterranean</span><i>·</i><span>Italian</span><i>·</i><span>BBQ &amp; Grill</span>
        <svg class="mq-ico" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 18h18"/><path d="M4.5 18a7.5 7.5 0 0 1 15 0"/><path d="M12 7.5V6"/><circle cx="12" cy="5" r="1"/></svg>
        <span>Asian Fusion</span><i>·</i><span>Fine Dining</span><i>·</i><span>Grazing Tables</span><i>·</i><span>Canapés</span><i>·</i><span>Wood-fired Pizza</span><i>·</i>
      </div>
    </div>
  </div>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="section hiw" id="how-it-works">
    <div class="container">
      <div class="head" data-reveal>
        <p class="section-label">How it works</p>
        <h2 class="h-display">From search to your event day in minutes.</h2>
      </div>

      <div class="hiw__grid">
        <article class="step" data-reveal data-delay="0">
          <div class="step__top">
            <span class="step__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </span>
            <span class="step__num">01</span>
          </div>
          <h3>Search</h3>
          <p>Enter your suburb, event type and guest count. Our filters surface the best-matched vetted caterers instantly.</p>
        </article>
        <article class="step" data-reveal data-delay="80">
          <div class="step__top">
            <span class="step__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>
            </span>
            <span class="step__num">02</span>
          </div>
          <h3>Compare</h3>
          <p>Browse full menus, per-head pricing, real photos and verified reviews. Every caterer is food-safety certified and insured.</p>
        </article>
        <article class="step" data-reveal data-delay="160">
          <div class="step__top">
            <span class="step__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4.5" width="18" height="16" rx="2.5"/><line x1="3" y1="9.5" x2="21" y2="9.5"/><line x1="8" y1="2.5" x2="8" y2="6"/><line x1="16" y1="2.5" x2="16" y2="6"/><polyline points="8.5 14.5 11 17 15.5 12.5"/></svg>
            </span>
            <span class="step__num">03</span>
          </div>
          <h3>Book</h3>
          <p>Customise your order, set the date, add dietary requirements. See your live total and confirm - all in one clean flow.</p>
        </article>
        <article class="step" data-reveal data-delay="240">
          <div class="step__top">
            <span class="step__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M6 13.87A4 4 0 0 1 7.41 6a5.11 5.11 0 0 1 1.05-1.54 5 5 0 0 1 7.08 0A5.11 5.11 0 0 1 16.59 6 4 4 0 0 1 18 13.87V21H6Z"/><line x1="6" y1="17" x2="18" y2="17"/></svg>
            </span>
            <span class="step__num">04</span>
          </div>
          <h3>Relax</h3>
          <p>Pay securely via Stripe. Get instant SMS and email confirmation. Your caterer shows up ready to impress.</p>
        </article>
      </div>

      <p class="hiw__note" data-reveal><span class="tick"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span> Every caterer vetted - Food safety · Insurance · ABN checked</p>
    </div>
  </section>

  <!-- ============ CATERER CARDS ============ -->
  <section class="section caterers" id="caterers">
    <div class="container">
      <div class="head head--row" data-reveal>
        <div>
          <p class="section-label">Browse caterers</p>
          <h2 class="h-display">Top-rated caterers across Melbourne.</h2>
        </div>
        <a href="/caterers" class="link-arrow">View all <%= stats.totalCaterers %>+ <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></a>
      </div>

      <div class="filters" data-reveal>
        <button class="filter filter--on" data-f="all">All</button>
        <button class="filter" data-f="corporate">Corporate</button>
        <button class="filter" data-f="wedding">Wedding</button>
        <button class="filter" data-f="party">Party</button>
        <button class="filter" data-f="italian">Italian</button>
        <button class="filter" data-f="asian">Asian</button>
        <button class="filter" data-f="bbq">BBQ</button>
      </div>

      <div class="cat-grid" id="cat-grid" data-total="<%= catTotal || 0 %>">
        <% if (caterers && caterers.length > 0) { %>
          <% caterers.forEach(function(cat, idx) { %>
          <%
            var delay = (idx % 3) * 60;
            var tagStr = 'all ' + (cat.occasions || []).join(' ');
            var imgSrc = cat.featured_image ? '/' + cat.featured_image : '/assets/food1.png';
            var ratingNum = parseFloat(cat.rating_avg || 0).toFixed(1);
            var priceNum = Math.round(parseFloat(cat.price_from || 0));
          %>
          <article class="card" data-tags="<%= tagStr %>" data-reveal data-delay="<%= delay %>">
            <a href="/caterer/<%= cat.slug %>" class="card__img" aria-label="View <%= cat.business_name %>">
              <img src="<%= imgSrc %>" alt="<%= cat.business_name %> catering" loading="lazy"/>
              <% if (cat.is_featured) { %>
              <span class="card__badge card__badge--top">★ Top Rated</span>
              <% } else { %>
              <span class="card__badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Vetted</span>
              <% } %>
            </a>
            <div class="card__body">
              <div class="card__row">
                <h3><a href="/caterer/<%= cat.slug %>"><%= cat.business_name %></a></h3>
                <span class="card__score"><%= ratingNum %> <small>★</small></span>
              </div>
              <p class="card__sub"><%= cat.suburb %>, Melbourne · ★★★★★ (<%= cat.review_count %>)</p>
              <p class="card__desc"><%= cat.tagline || cat.cuisine_type %></p>
              <div class="card__tags"><% (cat.tags || []).slice(0, 3).forEach(function(t) { %><span><%= t %></span><% }) %></div>
              <div class="card__foot">
                <span class="card__price">from <strong>$<%= priceNum %></strong>/pp</span>
                <a href="/caterer/<%= cat.slug %>" class="btn btn--line btn--sm">View &amp; Book</a>
              </div>
            </div>
          </article>
          <% }) %>
        <% } else { %>
          <p style="grid-column:1/-1;padding:2rem;color:#8a857a;text-align:center">No caterers listed yet. Check back soon!</p>
        <% } %>
      </div>
      <div id="cat-pager" hidden></div>
    </div>
  </section>

  <!-- ============ OCCASIONS (scroll-linked carousel) ============ -->
  <section class="occasions" id="occasions">
    <div class="occ-pin" id="occ-pin">
      <div class="occ-sticky">
        <div class="container occ-top">
          <div class="head" data-reveal>
            <p class="section-label">Every occasion</p>
            <h2 class="h-display">Whatever your event, we have the caterer.</h2>
          </div>
          <p class="occ-hint">Scroll to explore <span aria-hidden="true"><svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span></p>
        </div>
        <div class="occ-viewport">
          <div class="occ-track" id="occ-track">
            <a href="/caterers?occasion=corporate" class="occ-card" data-filter-occasion="corporate">
              <img src="/assets/corporate.png" alt="Corporate event catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Corporate Events</span>
                <p>Board lunches, product launches, team days, annual dinners, client entertainment.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers?occasion=wedding" class="occ-card" data-filter-occasion="wedding">
              <img src="/assets/wedding.png" alt="Wedding catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Weddings</span>
                <p>Cocktail receptions, seated dinners, grazing tables, dessert stations.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers?occasion=party" class="occ-card" data-filter-occasion="party">
              <img src="/assets/party.png" alt="Party catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Parties</span>
                <p>Birthdays, baby showers, house warmings, graduations and celebrations.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers" class="occ-card">
              <img src="/assets/food3.png" alt="Private dining catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Private Dining</span>
                <p>Intimate chef experiences, exclusive dinner parties, degustation menus.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers" class="occ-card">
              <img src="/assets/catering_spread.png" alt="Gala dinner catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Gala Dinners</span>
                <p>Award nights, fundraisers and milestone celebrations with elegant plated service.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers" class="occ-card">
              <img src="/assets/hero.png" alt="Conference catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Conferences</span>
                <p>Multi-day catering, breakout refreshments, working lunches and networking canapés.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers" class="occ-card">
              <img src="/assets/food1.png" alt="Christmas party catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Christmas Parties</span>
                <p>End-of-year celebrations, festive grazing, shared feasts and dessert stations.</p>
                <span class="occ-card__link">Browse caterers <svg class="i-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg></span>
              </div>
            </a>
            <a href="/caterers?occasion=corporate" class="occ-card" data-filter-occasion="corporate">
              <img src="/assets/food4.png" alt="Product launch catering" loading="lazy"/>
              <div class="occ-card__body">
                <span class="occ-card__tag">Product Launches</span>
                <p>Brand events, canapés, cocktail receptions and statement grazing tables.</p>
