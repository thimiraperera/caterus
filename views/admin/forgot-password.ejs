<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Forgot Password | Caterus Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/admin.css">
</head>
<body class="admin-body">
  <div class="login-page">
    <div class="login-card">
      <div class="login-logo"><span class="logo-dot"></span>caterus</div>
      <p class="login-sub">Reset Password</p>
      <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
        <div class="flash flash-success" style="margin-bottom:18px"><span><%= success %></span></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div class="flash flash-error" style="margin-bottom:18px"><span><%= error %></span></div>
      <% } %>
      <p style="font-size:0.9rem;color:var(--muted,#888);margin-bottom:20px">Enter your admin email address and we'll send you a password reset link.</p>
      <form method="POST" action="/admin/forgot-password">
        <div class="form-group">
          <label class="form-label" for="email">Email address</label>
          <input class="form-control" type="email" id="email" name="email" placeholder="admin@caterus.com.au" required autofocus>
        </div>
        <button class="btn btn-primary" type="submit">Send reset link</button>
      </form>
      <p style="margin-top:20px;text-align:center;font-size:0.88rem">
        <a href="/admin/login" style="color:var(--primary,#75896d);text-decoration:none">Back to login</a>
      </p>
    </div>
  </div>
</body>
</html>
