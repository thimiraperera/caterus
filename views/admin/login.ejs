<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Login | Caterus</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/admin.css">
</head>
<body class="admin-body">
  <div class="login-page">
    <div class="login-card">
      <div class="login-logo">
        <% if (loginLogo) { %>
          <img src="/<%= loginLogo %>" alt="Logo" style="max-height:52px;max-width:180px;object-fit:contain;display:block;margin:0 auto 4px">
        <% } else { %>
          <span class="logo-dot"></span>caterus
        <% } %>
      </div>
      <p class="login-sub">Admin Dashboard</p>
      <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
        <div class="flash flash-success" style="margin-bottom:18px"><span><%= success %></span></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div class="flash flash-error" style="margin-bottom:18px"><span><%= error %></span></div>
      <% } %>
      <form method="POST" action="/admin/login" id="login-form">
        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input class="form-control" type="email" id="email" name="email" placeholder="admin@caterus.com.au" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input class="form-control" type="password" id="password" name="password" placeholder="Enter password" required>
        </div>
        <div class="form-group" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
          <label style="display:flex;align-items:center;gap:8px;font-size:0.88rem;cursor:pointer;color:var(--ink-soft,#555)">
            <input type="checkbox" name="remember_me" value="1" style="width:16px;height:16px;cursor:pointer;accent-color:var(--primary,#75896d)">
            Remember me for 30 days
          </label>
          <a href="/admin/forgot-password" style="font-size:0.85rem;color:var(--primary,#75896d);text-decoration:none">Forgot password?</a>
        </div>
        <% if (captchaType === 'recaptcha_v2') { %>
        <div class="g-recaptcha" data-sitekey="<%= captchaSiteKey %>" style="margin-bottom:16px"></div>
        <% } else if (captchaType === 'hcaptcha') { %>
        <div class="h-captcha" data-sitekey="<%= captchaSiteKey %>" style="margin-bottom:16px"></div>
        <% } else if (captchaType === 'recaptcha_v3') { %>
        <input type="hidden" name="captcha_token" id="captcha_token_field">
        <% } %>
        <button class="btn btn-primary" type="submit" id="login-btn">Log in</button>
      </form>
    </div>
  </div>
  <% if (captchaType === 'recaptcha_v2') { %>
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>
  <% } else if (captchaType === 'hcaptcha') { %>
  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <% } else if (captchaType === 'recaptcha_v3') { %>
  <script src="https://www.google.com/recaptcha/api.js?render=<%= captchaSiteKey %>"></script>
  <script>
  document.getElementById('login-form').addEventListener('submit', function(e) {
    e.preventDefault();
    var form = this;
    grecaptcha.ready(function() {
      grecaptcha.execute('<%= captchaSiteKey %>', { action: 'login' }).then(function(token) {
        document.getElementById('captcha_token_field').value = token;
        form.submit();
      });
    });
  });
  </script>
  <% } %>
</body>
</html>
