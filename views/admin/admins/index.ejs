<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
  <div class="flash flash-success" style="margin-bottom:20px"><span><%= success %></span></div>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div class="flash flash-error" style="margin-bottom:20px"><span><%= error %></span></div>
<% } %>

<div class="settings-grid">

  <!-- Admin list -->
  <div class="settings-col">
    <div class="form-section">
      <h3 class="form-section__title">All Admins</h3>
      <% if (admins.length === 0) { %>
        <p style="color:var(--muted);font-size:0.9rem">No admins found.</p>
      <% } else { %>
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% admins.forEach(function(a) { %>
          <tr>
            <td><strong><%= a.name || '—' %></strong></td>
            <td><%= a.email %></td>
            <td><span class="badge badge-<%= a.role === 'super' ? 'success' : 'info' %>"><%= a.role || 'admin' %></span></td>
            <td style="font-size:0.82rem;color:var(--muted)"><%= new Date(a.created_at).toLocaleDateString('en-AU') %></td>
            <td style="text-align:right">
              <% if (a.id !== currentAdminId) { %>
              <form method="POST" action="/admin/admins/<%= a.id %>?_method=DELETE" style="display:inline" onsubmit="return confirm('Delete admin <%= a.name || a.email %>?')">
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
              </form>
              <% } else { %>
              <span style="font-size:0.8rem;color:var(--muted)">You</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>

  <!-- Create admin form -->
  <div class="settings-col">
    <div class="form-section">
      <h3 class="form-section__title">Add New Admin</h3>
      <form method="POST" action="/admin/admins">
        <div class="form-group">
          <label class="form-label">Full name</label>
          <input type="text" name="name" class="form-control" placeholder="Jane Smith" required>
        </div>
        <div class="form-group">
          <label class="form-label">Email address</label>
          <input type="email" name="email" class="form-control" placeholder="jane@caterus.com.au" required>
        </div>
        <div class="form-group">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="At least 8 characters" minlength="8" required>
        </div>
        <div class="form-group">
          <label class="form-label">Role</label>
          <select name="role" class="form-control">
            <option value="admin">Admin</option>
            <option value="super">Super Admin</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary">Create Admin</button>
      </form>
    </div>
  </div>

</div>
