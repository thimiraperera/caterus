<div style="display:flex;align-items:center;justify-content:flex-end;margin-bottom:20px">
  <a href="/" target="_blank" rel="noopener" class="btn btn-secondary" style="display:inline-flex;align-items:center;gap:8px">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    Visit Front-end
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
  </a>
</div>

<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-card__label">Total Revenue</div>
    <div class="stat-card__value"><%= formatCurrency(bookingStats.totalRevenue || 0) %></div>
    <div class="stat-card__trend">This month: <%= formatCurrency(bookingStats.monthlyRevenue || 0) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Bookings</div>
    <div class="stat-card__value"><%= bookingStats.totalBookings || 0 %></div>
    <div class="stat-card__trend"><%= bookingStats.monthlyCount || 0 %> this month</div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Active Caterers</div>
    <div class="stat-card__value"><%= catererStats.activeCaterers || 0 %></div>
    <div class="stat-card__trend"><%= catererStats.avgRating || 0 %> avg rating</div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Reviews</div>
    <div class="stat-card__value"><%= reviewStats.total || 0 %></div>
    <div class="stat-card__trend"><%= reviewStats.pending || 0 %> pending</div>
  </div>
</div>

<% if (newEnquiries > 0 || newApplications > 0) { %>
<div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:24px">
  <% if (newEnquiries > 0) { %><a href="/admin/enquiries" class="badge badge-pending" style="font-size:0.82rem;padding:8px 16px"><%= newEnquiries %> new enquir<%= newEnquiries > 1 ? 'ies' : 'y' %></a><% } %>
  <% if (newApplications > 0) { %><a href="/admin/applications" class="badge badge-new" style="font-size:0.82rem;padding:8px 16px"><%= newApplications %> new application<%= newApplications > 1 ? 's' : '' %></a><% } %>
</div>
<% } %>

<div class="card">
  <div class="card-header">
    <h2 class="card-title">Recent Bookings</h2>
    <div style="display:flex;align-items:center;gap:12px">
      <select class="form-control" id="db-per-page" style="max-width:130px">
        <option value="5"  <%=per_page===5?'selected':''%>>5 per page</option>
        <option value="10" <%=per_page===10?'selected':''%>>10 per page</option>
        <option value="25" <%=per_page===25?'selected':''%>>25 per page</option>
        <option value="50" <%=per_page===50?'selected':''%>>50 per page</option>
      </select>
      <a href="/admin/bookings" class="btn btn-secondary btn-sm">View all</a>
    </div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;padding:0 0 14px">
    <input type="text" id="db-search" class="form-control" placeholder="Ref, name, email..." style="flex:1;min-width:140px;max-width:210px" value="<%= dfSearch %>">
    <input type="text" id="db-caterer" class="form-control" placeholder="Caterer..." style="flex:1;min-width:120px;max-width:180px" value="<%= dfCaterer %>">
    <input type="date" id="db-date-from" class="form-control" style="min-width:140px;max-width:160px" value="<%= dfDateFrom %>">
    <input type="date" id="db-date-to" class="form-control" style="min-width:140px;max-width:160px" value="<%= dfDateTo %>">
    <div style="display:flex;align-items:center;gap:6px;flex-shrink:0">
      <span style="font-size:0.78rem;color:var(--muted);white-space:nowrap">Total $</span>
      <input type="number" id="db-total-min" class="form-control" placeholder="Min" min="0" step="100" style="width:82px" value="<%= dfTotalMin %>">
      <span style="color:var(--muted)">-</span>
      <input type="number" id="db-total-max" class="form-control" placeholder="Max" min="0" step="100" style="width:82px" value="<%= dfTotalMax %>">
    </div>
  </div>
  <div id="db-table-wrap">
    <%- include('./dashboard/_bookings', { bookings: bookings || [], bookingPage, bookingTotalPages, per_page, queryExtra, formatCurrency, formatDate }) %>
  </div>
</div>

<script>
(function() {
  var wrap = document.getElementById('db-table-wrap');
  var dbt;
  var currentPerPage = '<%= per_page %>';

  function load(extra) {
    extra = extra || {};
    var params = new URLSearchParams();
    var s = document.getElementById('db-search').value;
    var c = document.getElementById('db-caterer').value;
    var df = document.getElementById('db-date-from').value;
    var dt = document.getElementById('db-date-to').value;
    var tmin = document.getElementById('db-total-min').value;
    var tmax = document.getElementById('db-total-max').value;
    if (s)    params.set('search', s);
    if (c)    params.set('caterer_search', c);
    if (df)   params.set('date_from', df);
    if (dt)   params.set('date_to', dt);
    if (tmin) params.set('total_min', tmin);
    if (tmax) params.set('total_max', tmax);
    params.set('per_page', currentPerPage);
    if (extra.page) params.set('page', extra.page);
    wrap.classList.add('table-loading');
    fetch('/admin?' + params.toString(), { headers: { 'X-Partial': '1' } })
      .then(function(r) { return r.text(); })
      .then(function(html) { wrap.innerHTML = html; wrap.classList.remove('table-loading'); })
      .catch(function() { wrap.classList.remove('table-loading'); });
    history.replaceState(null, '', location.pathname + '?' + params.toString());
  }

  function schedule() { clearTimeout(dbt); dbt = setTimeout(load, 320); }

  document.getElementById('db-search').addEventListener('input', schedule);
  document.getElementById('db-caterer').addEventListener('input', schedule);
  document.getElementById('db-total-min').addEventListener('input', schedule);
  document.getElementById('db-total-max').addEventListener('input', schedule);
  document.getElementById('db-date-from').addEventListener('change', function() { load(); });
  document.getElementById('db-date-to').addEventListener('change', function() { load(); });
  document.getElementById('db-per-page').addEventListener('change', function() {
    currentPerPage = this.value; load();
  });

  wrap.addEventListener('click', function(e) {
    var btn = e.target.closest('a.pg-btn');
    if (!btn) return;
    e.preventDefault();
    load({ page: new URL(btn.href).searchParams.get('page') });
  });
})();
</script>
