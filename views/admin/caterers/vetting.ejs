<%- include('../../partials/caterer-actions', { caterer, currentAction: 'vetting' }) %>

<div class="caterer-grid">
  <div class="caterer-col">
    <div class="form-section">
      <h3 class="form-section__title">Vetting Checklist</h3>
      <form method="POST" action="/admin/caterers/<%= caterer.id %>/vetting">
        <div class="checklist-item<%= vetting && vetting.food_safety_cert ? ' checked' : '' %>">
          <label class="checkbox"><input type="checkbox" name="food_safety_cert" value="on" <%= vetting && vetting.food_safety_cert ? 'checked' : '' %>></label>
          <div style="flex:1">
            <strong>Food Safety Certificate</strong>
            <div class="form-row" style="margin-top:8px">
              <div class="form-group"><label class="form-label">Expiry Date</label><input type="date" name="food_safety_expiry" class="form-control" value="<%= vetting && vetting.food_safety_expiry ? vetting.food_safety_expiry.slice(0,10) : '' %>"></div>
            </div>
          </div>
        </div>

        <div class="checklist-item<%= vetting && vetting.public_liability ? ' checked' : '' %>">
          <label class="checkbox"><input type="checkbox" name="public_liability" value="on" <%= vetting && vetting.public_liability ? 'checked' : '' %>></label>
          <div style="flex:1">
            <strong>Public Liability Insurance</strong>
            <div class="form-row" style="margin-top:8px">
              <div class="form-group"><label class="form-label">Amount</label><input type="text" name="liability_amount" class="form-control" value="<%= vetting ? vetting.liability_amount || '' : '' %>" placeholder="e.g. $20M"></div>
              <div class="form-group"><label class="form-label">Expiry</label><input type="date" name="liability_expiry" class="form-control" value="<%= vetting && vetting.liability_expiry ? vetting.liability_expiry.slice(0,10) : '' %>"></div>
            </div>
          </div>
        </div>

        <div class="checklist-item<%= vetting && vetting.abn_verified ? ' checked' : '' %>">
          <label class="checkbox"><input type="checkbox" name="abn_verified" value="on" <%= vetting && vetting.abn_verified ? 'checked' : '' %>></label>
          <div><strong>ABN Verified</strong></div>
        </div>

        <div class="checklist-item<%= vetting && vetting.quality_check ? ' checked' : '' %>">
          <label class="checkbox"><input type="checkbox" name="quality_check" value="on" <%= vetting && vetting.quality_check ? 'checked' : '' %>></label>
          <div style="flex:1">
            <strong>Quality Check Passed</strong>
            <div class="form-group" style="margin-top:8px"><textarea name="quality_notes" class="form-control" placeholder="Notes..."><%= vetting ? vetting.quality_notes || '' : '' %></textarea></div>
          </div>
        </div>

        <div style="display:flex;gap:12px;margin-top:20px">
          <button type="submit" class="btn btn-primary">Save Vetting</button>
        </div>
      </form>
    </div>
  </div>

  <div class="caterer-col">
    <div class="form-section">
      <h3 class="form-section__title">Approval Status</h3>
      <% if (vetting && vetting.approved_at) { %>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
          <span class="badge badge-confirmed">Approved</span>
          <span style="font-size:0.88rem;color:var(--muted)">by <%= vetting.approved_by_name || 'Admin' %></span>
        </div>
        <p style="font-size:0.82rem;color:var(--ink-soft);margin-bottom:16px"><%= vetting.approved_at %></p>
        <form method="POST" action="/admin/caterers/<%= caterer.id %>/vetting">
          <input type="hidden" name="revoke_approval" value="1">
          <input type="hidden" name="food_safety_cert" value="<%= vetting.food_safety_cert ? 'on' : '' %>">
          <input type="hidden" name="public_liability" value="<%= vetting.public_liability ? 'on' : '' %>">
          <input type="hidden" name="abn_verified" value="<%= vetting.abn_verified ? 'on' : '' %>">
          <input type="hidden" name="quality_check" value="<%= vetting.quality_check ? 'on' : '' %>">
          <button type="submit" class="btn btn-secondary btn-sm" onclick="return confirm('Revoke approval for this caterer?')">Revoke Approval</button>
        </form>
      <% } else { %>
        <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">Not yet approved.</p>
        <form method="POST" action="/admin/caterers/<%= caterer.id %>/vetting">
          <input type="hidden" name="manual_approve" value="1">
          <input type="hidden" name="food_safety_cert" value="<%= vetting && vetting.food_safety_cert ? 'on' : '' %>">
          <input type="hidden" name="public_liability" value="<%= vetting && vetting.public_liability ? 'on' : '' %>">
          <input type="hidden" name="abn_verified" value="<%= vetting && vetting.abn_verified ? 'on' : '' %>">
          <input type="hidden" name="quality_check" value="<%= vetting && vetting.quality_check ? 'on' : '' %>">
          <button type="submit" class="btn btn-primary btn-sm">Approve Manually</button>
        </form>
      <% } %>

      <div style="margin-top:20px">
        <h4 style="font-size:0.88rem;font-weight:700;margin-bottom:4px">Checklist Summary</h4>
        <p style="font-size:0.78rem;color:var(--muted);margin-bottom:10px">Reflects the checklist saved on the left.</p>
        <% const checks = [
          ['Food Safety', vetting && vetting.food_safety_cert],
          ['Public Liability', vetting && vetting.public_liability],
          ['ABN Verified', vetting && vetting.abn_verified],
          ['Quality Check', vetting && vetting.quality_check],
        ]; %>
        <% checks.forEach(([label, done]) => { %>
        <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--line)">
          <span style="font-size:1rem;<%=done?'color:#3d5a36':'color:var(--muted)'%>"><%=done?'✓':'○'%></span>
          <span style="font-size:0.88rem;color:<%=done?'var(--ink)':'var(--muted)'%>"><%= label %></span>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Caterer Details</h3>
      <div style="font-size:0.88rem">
        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--line)"><span style="color:var(--muted)">Business</span><strong><%= caterer.business_name %></strong></div>
        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--line)"><span style="color:var(--muted)">ABN</span><span><%= caterer.abn || 'Not set' %></span></div>
        <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--line)"><span style="color:var(--muted)">Contact</span><span><%= caterer.contact_name || 'Not set' %></span></div>
        <div style="display:flex;justify-content:space-between;padding:6px 0"><span style="color:var(--muted)">Status</span><span class="badge badge-<%= caterer.status %>"><%= caterer.status %></span></div>
      </div>
    </div>
  </div>
</div>
