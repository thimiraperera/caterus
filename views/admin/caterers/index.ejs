<div class="page-header">
  <h2><%= total %> caterer<%= total !== 1 ? 's' : '' %></h2>
  <a href="/admin/caterers/create" class="btn btn-primary">+ Add Caterer</a>
</div>

<div class="filter-bar">
  <div class="filter-tabs">
    <a href="/admin/caterers" class="filter-tab<%= !caterers.length || !true ? '' : ' active' %>">All</a>
    <a href="/admin/caterers?status=active" class="filter-tab">Active</a>
    <a href="/admin/caterers?status=draft" class="filter-tab">Draft</a>
    <a href="/admin/caterers?status=pending" class="filter-tab">Pending</a>
  </div>
  <form method="GET" action="/admin/caterers" style="flex:1;max-width:300px">
    <input type="text" name="search" class="form-control" placeholder="Search caterers…" value="<%= typeof caterers !== 'undefined' ? '' : '' %>">
  </form>
</div>

<% if (caterers.length === 0) { %>
<div class="empty-state"><p>No caterers found.</p><a href="/admin/caterers/create" class="btn btn-primary">Add your first caterer</a></div>
<% } else { %>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr><th></th><th>Business Name</th><th>Cuisine</th><th>Suburb</th><th>Rating</th><th>Status</th><th>Actions</th></tr>
    </thead>
    <tbody>
      <% caterers.forEach(c => { %>
      <tr>
        <td><% if (c.featured_image) { %><img src="/<%= c.featured_image %>" class="thumb" alt=""><% } else { %><div class="thumb"></div><% } %></td>
        <td><a href="/admin/caterers/<%= c.id %>/edit"><strong><%= c.business_name %></strong></a></td>
        <td><%= c.cuisine_type || '-' %></td>
        <td><%= c.suburb || '-' %></td>
        <td>★ <%= c.rating_avg %> (<%= c.review_count %>)</td>
        <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
        <td class="actions">
          <a href="/admin/caterers/<%= c.id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
          <a href="/admin/caterers/<%= c.id %>/menus" class="btn btn-secondary btn-sm">Menus</a>
          <a href="/admin/caterers/<%= c.id %>/vetting" class="btn btn-secondary btn-sm">Vetting</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../../partials/pagination', { baseUrl: '/admin/caterers', page, totalPages }) %>
<% } %>
