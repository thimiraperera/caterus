<div class="page-header">
  <h2 id="caterer-count"><%= total %> caterer<%= total !== 1 ? 's' : '' %></h2>
  <a href="/admin/caterers/create" class="btn btn-primary">+ Add Caterer</a>
</div>

<div class="filter-bar">
  <div class="filter-tabs" id="caterer-status-tabs">
    <a href="/admin/caterers" class="filter-tab<%= !currentStatus ? ' active' : '' %>" data-status="">All</a>
    <a href="/admin/caterers?status=active" class="filter-tab<%= currentStatus==='active' ? ' active' : '' %>" data-status="active">Active</a>
    <a href="/admin/caterers?status=draft" class="filter-tab<%= currentStatus==='draft' ? ' active' : '' %>" data-status="draft">Draft</a>
    <a href="/admin/caterers?status=pending" class="filter-tab<%= currentStatus==='pending' ? ' active' : '' %>" data-status="pending">Pending</a>
  </div>
  <input type="text" id="caterer-search" class="form-control" style="flex:1;max-width:220px"
    placeholder="Business name..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
  <input type="text" id="caterer-cuisine" class="form-control" style="flex:1;max-width:160px"
    placeholder="Cuisine..." value="<%= typeof cfCuisine !== 'undefined' ? cfCuisine : '' %>">
  <input type="text" id="caterer-suburb" class="form-control" style="flex:1;max-width:160px"
    placeholder="Suburb..." value="<%= typeof cfSuburb !== 'undefined' ? cfSuburb : '' %>">
  <select id="caterer-rating" class="form-control" style="flex:1;max-width:150px">
    <option value="" <%=(typeof cfRating==='undefined'||cfRating==='')?'selected':''%>>Any rating</option>
    <option value="3"   <%=cfRating==='3'  ?'selected':''%>>3+ stars</option>
    <option value="4"   <%=cfRating==='4'  ?'selected':''%>>4+ stars</option>
    <option value="4.5" <%=cfRating==='4.5'?'selected':''%>>4.5+ stars</option>
  </select>
  <select class="per-page-select form-control"
    onchange="const p=new URLSearchParams(location.search);p.set('per_page',this.value);p.delete('page');location.href=location.pathname+'?'+p.toString()">
    <option value="10"  <%=per_page===10?'selected':''%>>10 / page</option>
    <option value="20"  <%=per_page===20?'selected':''%>>20 / page</option>
    <option value="50"  <%=per_page===50?'selected':''%>>50 / page</option>
    <option value="100" <%=per_page===100?'selected':''%>>100 / page</option>
  </select>
</div>

<div id="caterers-table-wrap">
  <%- include('./_table', { caterers, page, totalPages, per_page, queryExtra, status: currentStatus }) %>
</div>

<script>
(function() {
  const wrap = document.getElementById('caterers-table-wrap');
  const searchInput  = document.getElementById('caterer-search');
  const cuisineInput = document.getElementById('caterer-cuisine');
  const suburbInput  = document.getElementById('caterer-suburb');
  const ratingInput  = document.getElementById('caterer-rating');
  const tabs = document.querySelectorAll('#caterer-status-tabs .filter-tab');
  const countEl = document.getElementById('caterer-count');
  let debounce;
  let currentStatus = '<%= currentStatus %>';
  let currentPerPage = '<%= per_page %>';

  async function load(params) {
    wrap.classList.add('table-loading');
    const url = new URL('/admin/caterers', location.origin);
    if (params.status)     url.searchParams.set('status', params.status);
    if (params.search)     url.searchParams.set('search', params.search);
    if (params.cuisine)    url.searchParams.set('cuisine', params.cuisine);
    if (params.suburb)     url.searchParams.set('suburb', params.suburb);
    if (params.rating_min) url.searchParams.set('rating_min', params.rating_min);
    url.searchParams.set('per_page', params.per_page || currentPerPage);
    if (params.page) url.searchParams.set('page', params.page);

    const res = await fetch(url, { headers: { 'X-Partial': '1' } });
    const html = await res.text();
    wrap.innerHTML = html;
    wrap.classList.remove('table-loading');
    history.replaceState(null, '', url.pathname + '?' + url.searchParams.toString());
  }

  function getFilterParams(extra) {
    return {
      status:     currentStatus,
      search:     searchInput.value,
      cuisine:    cuisineInput.value,
      suburb:     suburbInput.value,
      rating_min: ratingInput.value,
      per_page:   currentPerPage,
      ...extra,
    };
  }

  [searchInput, cuisineInput, suburbInput].forEach(function(inp) {
    inp.addEventListener('input', function() {
      clearTimeout(debounce);
      debounce = setTimeout(() => load(getFilterParams()), 280);
    });
  });
  ratingInput.addEventListener('change', function() { load(getFilterParams()); });

  tabs.forEach(tab => {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      currentStatus = this.dataset.status || '';
      tabs.forEach(t => t.classList.remove('active'));
      this.classList.add('active');
      load(getFilterParams());
    });
  });

  wrap.addEventListener('click', function(e) {
    const pgBtn = e.target.closest('a.pg-btn');
    if (!pgBtn) return;
    e.preventDefault();
    const page = new URL(pgBtn.href).searchParams.get('page');
    load(getFilterParams({ page }));
  });
})();
</script>
