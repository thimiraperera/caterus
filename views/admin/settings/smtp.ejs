<div class="settings-grid">

  <div class="settings-col">
    <div class="form-section">
      <h3 class="form-section__title">SMTP / Email Settings</h3>
      <form method="POST" action="/admin/settings?_method=PUT">
        <input type="hidden" name="group" value="smtp">
        <div class="form-group"><label class="form-label">SMTP Host</label><input type="text" name="smtp_host" class="form-control" value="<%= settings.smtp_host || '' %>" placeholder="e.g. smtp.gmail.com"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">SMTP Port</label><input type="text" name="smtp_port" class="form-control" value="<%= settings.smtp_port || '587' %>"></div>
          <div class="form-group">
            <label class="form-label">Encryption</label>
            <select name="smtp_secure" class="form-control">
              <option value="tls"  <%=settings.smtp_secure==='tls'  ?'selected':''%>>TLS (port 587)</option>
              <option value="ssl"  <%=settings.smtp_secure==='ssl'  ?'selected':''%>>SSL (port 465)</option>
              <option value="none" <%=settings.smtp_secure==='none' ?'selected':''%>>None</option>
            </select>
          </div>
        </div>
        <div class="form-group"><label class="form-label">SMTP Username</label><input type="text" name="smtp_user" class="form-control" value="<%= settings.smtp_user || '' %>" autocomplete="off"></div>
        <div class="form-group"><label class="form-label">SMTP Password</label><input type="password" name="smtp_pass" class="form-control" value="<%= settings.smtp_pass || '' %>" autocomplete="new-password"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">From Email</label><input type="email" name="smtp_from_email" class="form-control" value="<%= settings.smtp_from_email || 'hello@caterus.com.au' %>"></div>
          <div class="form-group"><label class="form-label">From Name</label><input type="text" name="smtp_from_name" class="form-control" value="<%= settings.smtp_from_name || 'Caterus' %>"></div>
        </div>
        <button type="submit" class="btn btn-primary">Save SMTP</button>
      </form>
    </div>
  </div>

  <div class="settings-col">
    <div class="form-section">
      <h3 class="form-section__title">Test SMTP</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">Send a test email to verify your SMTP settings are working correctly.</p>
      <form method="POST" action="/admin/settings/smtp/test">
        <div class="form-group">
          <label class="form-label">Send test email to</label>
          <input type="email" name="test_email" class="form-control" placeholder="your@email.com" required>
        </div>
        <button type="submit" class="btn btn-secondary">Send Test Email</button>
      </form>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Setup Guide</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:10px">Common SMTP provider settings:</p>
      <table style="font-size:0.82rem;width:100%;border-collapse:collapse">
        <thead><tr style="text-align:left"><th style="padding:4px 8px;border-bottom:1px solid var(--line)">Provider</th><th style="padding:4px 8px;border-bottom:1px solid var(--line)">Host</th><th style="padding:4px 8px;border-bottom:1px solid var(--line)">Port</th></tr></thead>
        <tbody>
          <tr><td style="padding:4px 8px">Gmail</td><td style="padding:4px 8px">smtp.gmail.com</td><td style="padding:4px 8px">587 TLS</td></tr>
          <tr><td style="padding:4px 8px">Outlook</td><td style="padding:4px 8px">smtp.office365.com</td><td style="padding:4px 8px">587 TLS</td></tr>
          <tr><td style="padding:4px 8px">cPanel</td><td style="padding:4px 8px">mail.yourdomain.com</td><td style="padding:4px 8px">465 SSL</td></tr>
          <tr><td style="padding:4px 8px">SendGrid</td><td style="padding:4px 8px">smtp.sendgrid.net</td><td style="padding:4px 8px">587 TLS</td></tr>
        </tbody>
      </table>
      <p style="font-size:0.78rem;color:var(--muted);margin-top:10px">For Gmail, use an App Password (not your Google account password).</p>
    </div>
  </div>

</div>
