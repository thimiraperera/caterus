<style>
.occ-item { display:flex; align-items:center; gap:16px; padding:14px; background:var(--surface); border:1px solid var(--line); border-radius:var(--radius-sm); margin-bottom:8px; }
.occ-item__img { width:80px; height:58px; border-radius:6px; overflow:hidden; flex-shrink:0; background:var(--surface-2); display:grid; place-items:center; border:1px solid var(--line); }
.occ-item__img img { width:100%; height:100%; object-fit:cover; }
.occ-item__img-ph { font-size:0.72rem; color:var(--muted); text-align:center; padding:4px; }
.occ-item__body { flex:1; min-width:0; }
.occ-item__body strong { font-size:0.94rem; display:block; }
.occ-item__body p { font-size:0.82rem; color:var(--muted); margin:2px 0 0; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
.occ-edit-panel { padding:16px; border:1px solid var(--accent); border-radius:var(--radius-sm); margin-top:-4px; margin-bottom:8px; background:var(--surface-2); display:none; }
.occ-edit-panel.open { display:block; }
</style>

<div class="settings-grid">

  <div class="settings-col">
    <div class="form-section">
      <h3 class="form-section__title">Add Occasion</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">Occasions appear on caterer profiles and the homepage search.</p>
      <form method="POST" action="/admin/settings/occasions" enctype="multipart/form-data">
        <div class="form-group">
          <label class="form-label">Occasion Name *</label>
          <input type="text" name="name" class="form-control" placeholder="e.g. Hen's Party" required autocomplete="off">
        </div>
        <div class="form-group">
          <label class="form-label">Description</label>
          <textarea name="description" class="form-control" rows="2" placeholder="Brief description shown on the homepage..."></textarea>
        </div>
        <div class="form-group">
          <label class="form-label">Featured Image <span style="color:var(--muted);font-weight:400">(optional)</span></label>
          <input type="file" name="occasion_image" class="form-control" accept="image/*">
        </div>
        <button type="submit" class="btn btn-primary">Add Occasion</button>
      </form>
    </div>
  </div>

  <div class="settings-col">
    <div class="form-section">
      <h3 class="form-section__title">Current Occasions (<%= occasions.length %>)</h3>
      <% if (occasions.length === 0) { %>
      <p style="font-size:0.88rem;color:var(--muted)">No occasions yet. Add one on the left.</p>
      <% } else { %>
      <% occasions.forEach(function(occ, idx) { %>
      <div class="occ-item" id="occ-row-<%= idx %>">
        <div class="occ-item__img">
          <% if (occ.image) { %>
          <img src="/<%= occ.image %>" alt="<%= occ.name %>">
          <% } else { %>
          <div class="occ-item__img-ph">No image</div>
          <% } %>
        </div>
        <div class="occ-item__body">
          <strong><%= occ.name %></strong>
          <p><%= occ.description || 'No description' %></p>
        </div>
        <div style="display:flex;gap:6px;flex-shrink:0">
          <button type="button" class="btn btn-secondary btn-sm" onclick="toggleOccEdit(<%= idx %>)">Edit</button>
          <form method="POST" action="/admin/settings/occasions/delete" style="margin:0">
            <input type="hidden" name="name" value="<%= occ.name %>">
            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Remove occasion: <%= occ.name %>?')">Remove</button>
          </form>
        </div>
      </div>
      <div class="occ-edit-panel" id="occ-edit-<%= idx %>">
        <form method="POST" action="/admin/settings/occasions/<%= idx %>/update" enctype="multipart/form-data">
          <div class="form-group">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-control" value="<%= occ.name %>" required>
          </div>
          <div class="form-group">
            <label class="form-label">Description</label>
            <textarea name="description" class="form-control" rows="2"><%= occ.description || '' %></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Replace Image <span style="color:var(--muted);font-weight:400">(optional)</span></label>
            <% if (occ.image) { %>
            <div style="margin-bottom:8px"><img src="/<%= occ.image %>" alt="" style="max-height:60px;border-radius:4px;border:1px solid var(--line)"></div>
            <% } %>
            <input type="file" name="occasion_image" class="form-control" accept="image/*">
          </div>
          <div style="display:flex;gap:8px">
            <button type="submit" class="btn btn-primary btn-sm">Save</button>
            <button type="button" class="btn btn-secondary btn-sm" onclick="toggleOccEdit(<%= idx %>)">Cancel</button>
          </div>
        </form>
      </div>
      <% }) %>
      <% } %>
    </div>
  </div>

</div>

<script>
function toggleOccEdit(idx) {
  var panel = document.getElementById('occ-edit-' + idx);
  panel.classList.toggle('open');
}
</script>
