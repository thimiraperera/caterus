  { id: 'facebook',  label: 'Facebook',  icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>' },
  { id: 'instagram', label: 'Instagram', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>' },
  { id: 'linkedin',  label: 'LinkedIn',  icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>' },
  { id: 'twitter',   label: 'X / Twitter', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>' },
  { id: 'youtube',   label: 'YouTube',   icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon fill="#fff" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>' },
  { id: 'tiktok',    label: 'TikTok',    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/></svg>' },
  { id: 'pinterest', label: 'Pinterest', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>' },
];
%>
<form method="POST" action="/admin/settings/contact">

<div class="settings-grid">

  <!-- LEFT COLUMN -->
  <div class="settings-col">

    <div class="form-section">
      <h3 class="form-section__title">Contact Details</h3>
      <p style="font-size:0.85rem;color:var(--muted);margin-bottom:18px">Shown in the site footer, contact modal, and partner application modal.</p>
      <div class="form-group">
        <label class="form-label">Public Email Address</label>
        <input type="email" name="contact_email" class="form-control" value="<%= settings.contact_email || '' %>" placeholder="hello@caterus.com.au">
      </div>
      <div class="form-group">
        <label class="form-label">Public Phone Number</label>
        <div style="display:flex;gap:8px">
          <select name="contact_phone_country" class="form-control" style="width:120px;flex-shrink:0">
            <% [
              ['+61','🇦🇺 +61'],['+64','🇳🇿 +64'],['+1','🇺🇸 +1'],['+44','🇬🇧 +44'],
              ['+91','🇮🇳 +91'],['+65','🇸🇬 +65'],['+60','🇲🇾 +60'],['+63','🇵🇭 +63'],
              ['+62','🇮🇩 +62'],['+66','🇹🇭 +66'],['+86','🇨🇳 +86'],['+81','🇯🇵 +81'],
              ['+971','🇦🇪 +971'],['+49','🇩🇪 +49'],['+33','🇫🇷 +33'],['+44','🇬🇧 +44'],
            ].forEach(c => { %>
              <option value="<%= c[0] %>" <%=(settings.contact_phone_country===c[0])||(!settings.contact_phone_country&&c[0]==='+61')?'selected':''%>><%= c[1] %></option>
            <% }) %>
          </select>
          <input type="tel" name="contact_phone" class="form-control" value="<%= settings.contact_phone || '' %>" placeholder="03 9000 0000">
        </div>
      </div>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Footer & Email</h3>
      <div class="form-group">
        <label class="form-label">Footer Tagline</label>
        <input type="text" name="footer_tagline" class="form-control" value="<%= settings.footer_tagline || '' %>" placeholder="Caterus Pty Ltd · Melbourne, Victoria, Australia">
        <p style="font-size:0.78rem;color:var(--muted);margin-top:4px">Shown after the auto-generated copyright year. Leave blank for default.</p>
      </div>
      <div class="form-group">
        <label class="form-label">Email Logo</label>
        <select name="email_logo_type" class="form-control">
          <option value="light" <%=settings.email_logo_type==='light'||!settings.email_logo_type?'selected':''%>>Light theme logo</option>
          <option value="dark"  <%=settings.email_logo_type==='dark'?'selected':''%>>Dark theme logo</option>
          <option value="none"  <%=settings.email_logo_type==='none'?'selected':''%>>No logo (text only)</option>
        </select>
        <p style="font-size:0.78rem;color:var(--muted);margin-top:4px">Which logo to show in the header of all outgoing emails.</p>
      </div>
    </div>

  </div>

  <!-- RIGHT COLUMN -->
  <div class="settings-col">

    <div class="form-section">
      <h3 class="form-section__title">Social Media</h3>
      <p style="font-size:0.85rem;color:var(--muted);margin-bottom:18px">Links appear in the site footer. Leave URL empty to hide a platform.</p>

      <div id="social-rows" style="display:flex;flex-direction:column;gap:12px;margin-bottom:16px">
        <% SOCIAL_PLATFORMS.forEach(function(p) {
             const existing = socialLinks.find(s => s.platform === p.id);
        %>
        <div style="display:flex;align-items:center;gap:10px">
          <span style="width:130px;display:flex;align-items:center;gap:8px;font-size:0.88rem;flex-shrink:0;color:var(--ink-soft)">
            <%- p.icon %> <%= p.label %>
          </span>
          <input type="hidden" name="social_platforms" value="<%= p.id %>">
          <input type="url" name="social_urls" class="form-control" value="<%= existing ? existing.url : '' %>" placeholder="https://">
        </div>
        <% }) %>
      </div>
    </div>

  </div>

</div>

<div style="margin-top:8px;padding:0 0 24px">
  <button type="submit" class="btn btn-primary">Save Contact &amp; Social</button>
</div>

</form>
