<div class="settings-grid">

  <!-- LEFT COLUMN -->
  <div class="settings-col">

    <div class="form-section">
      <h3 class="form-section__title">Logo</h3>
      <% if (logoPath) { %>
      <div style="margin-bottom:16px">
        <img src="/<%= logoPath %>" alt="Site logo" style="max-height:60px;max-width:240px;object-fit:contain;border:1px solid var(--border-color,#e8e4dc);border-radius:8px;padding:8px;background:#fff;">
      </div>
      <% } %>
      <form method="POST" action="/admin/settings/logo" enctype="multipart/form-data">
        <div class="form-group">
          <label class="form-label">Upload logo <span style="color:var(--muted);font-weight:400">(PNG, SVG or JPEG, max 10 MB)</span></label>
          <input type="file" name="logo" class="form-control" accept="image/png,image/jpeg,image/svg+xml,image/webp" required>
        </div>
        <button type="submit" class="btn btn-primary">Upload logo</button>
      </form>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Site Settings</h3>
      <form method="POST" action="/admin/settings?_method=PUT">
        <input type="hidden" name="group" value="general">
        <div class="form-group"><label class="form-label">Site Name</label><input type="text" name="site_name" class="form-control" value="<%= settings.site_name || 'Caterus' %>"></div>
        <div class="form-group"><label class="form-label">Tagline</label><input type="text" name="site_tagline" class="form-control" value="<%= settings.site_tagline || '' %>"></div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Commission Rate (%)</label><input type="number" name="commission_rate" class="form-control" step="0.01" value="<%= settings.commission_rate || '12' %>"></div>
          <div class="form-group"><label class="form-label">GST Rate (%)</label><input type="number" name="gst_rate" class="form-control" step="0.01" value="<%= settings.gst_rate || '10' %>"></div>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
      </form>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">CAPTCHA</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:18px">Protect public forms (contact, enquiry, applications) with a CAPTCHA provider.</p>
      <form method="POST" action="/admin/settings?_method=PUT">
        <input type="hidden" name="group" value="captcha">
        <input type="hidden" name="_redirect" value="/admin/settings/general">
        <div class="form-group">
          <label class="form-label">CAPTCHA Provider</label>
          <select name="captcha_type" class="form-control" id="captcha-type-select">
            <option value="none"         <%=settings.captcha_type==='none'||!settings.captcha_type?'selected':''%>>None</option>
            <option value="recaptcha_v2" <%=settings.captcha_type==='recaptcha_v2'?'selected':''%>>Google reCAPTCHA v2 (Checkbox)</option>
            <option value="recaptcha_v3" <%=settings.captcha_type==='recaptcha_v3'?'selected':''%>>Google reCAPTCHA v3 (Invisible)</option>
            <option value="hcaptcha"     <%=settings.captcha_type==='hcaptcha'?'selected':''%>>hCaptcha</option>
          </select>
        </div>
        <div id="captcha-keys" style="display:<%= settings.captcha_type && settings.captcha_type !== 'none' ? 'block' : 'none' %>">
          <div class="form-group">
            <label class="form-label">Site Key</label>
            <input type="text" name="captcha_site_key" class="form-control" value="<%= settings.captcha_site_key || '' %>" placeholder="Site key from your provider dashboard">
          </div>
          <div class="form-group">
            <label class="form-label">Secret Key</label>
            <input type="password" name="captcha_secret_key" class="form-control" value="<%= settings.captcha_secret_key || '' %>" placeholder="Secret key from your provider dashboard">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Save CAPTCHA</button>
      </form>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Sitemap</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:14px">The sitemap is generated automatically from all published caterers. Search engines are pointed to it via <code>robots.txt</code>.</p>
      <a href="/sitemap.xml" target="_blank" class="btn btn-secondary btn-sm">View sitemap.xml</a>
    </div>

  </div>

  <!-- RIGHT COLUMN -->
  <div class="settings-col">

    <div class="form-section">
      <h3 class="form-section__title">Search Engine Visibility</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">While in testing, you can block all search engines from indexing this site. This sets <code>Disallow: /</code> in <code>robots.txt</code>.</p>
      <form method="POST" action="/admin/settings?_method=PUT">
        <input type="hidden" name="group" value="general">
        <input type="hidden" name="_redirect" value="/admin/settings/general">
        <div class="form-group">
          <input type="hidden" name="noindex" value="0">
          <label class="toggle" style="cursor:pointer;display:inline-flex;align-items:center;gap:12px">
            <input type="checkbox" id="noindex-toggle" name="noindex" value="1" <%=settings.noindex==='1'?'checked':''%> onchange="this.form.submit()">
            <span class="toggle-track"></span>
            <span class="toggle-label">Discourage search engines (noindex)</span>
          </label>
        </div>
      </form>
      <p style="font-size:0.78rem;color:var(--muted);margin-top:8px">Note: search engines may ignore this. Remove the toggle when you go live.</p>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Backup</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">Download a copy of your data. For media, FTP access to <code>public/assets/uploads/</code> is faster for large sets.</p>
      <div style="display:flex;flex-wrap:wrap;gap:10px">
        <a href="/admin/settings/backup/db" class="btn btn-secondary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Database (.sql)
        </a>
        <a href="/admin/settings/backup/media" class="btn btn-secondary">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download Media (.zip)
        </a>
      </div>
      <p style="font-size:0.78rem;color:var(--muted);margin-top:10px">Media is organised in <code>uploads/YYYY/MM/</code> folders like WordPress. You can back it up by FTP without downloading through the browser.</p>
    </div>

    <div class="form-section">
      <h3 class="form-section__title">Restore</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">Upload a backup file to restore. Database restore will overwrite all data.</p>
      <div style="display:flex;flex-direction:column;gap:16px">
        <form method="POST" action="/admin/settings/restore/db" enctype="multipart/form-data">
          <label class="form-label">Restore Database (.sql)</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="file" name="sql_file" class="form-control" accept=".sql,text/plain" required style="flex:1">
            <button type="submit" class="btn btn-secondary" onclick="return confirm('This will overwrite the current database. Continue?')">Restore DB</button>
          </div>
        </form>
        <form method="POST" action="/admin/settings/restore/media" enctype="multipart/form-data">
          <label class="form-label">Restore Media (.zip)</label>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="file" name="zip_file" class="form-control" accept=".zip,application/zip" required style="flex:1">
            <button type="submit" class="btn btn-secondary">Restore Media</button>
          </div>
        </form>
      </div>
    </div>

    <div class="form-section" style="border-color:rgba(220,53,69,0.3)">
      <h3 class="form-section__title" style="color:#dc3545">Erase Test Data</h3>
      <p style="font-size:0.88rem;color:var(--muted);margin-bottom:16px">Deletes all bookings, payments, reviews, enquiries, applications and sessions. <strong>Does not</strong> delete caterers, admins, menus, FAQs or settings.</p>
      <form method="POST" action="/admin/settings/erase-test-data">
        <button type="submit" class="btn btn-danger" onclick="return confirm('This will permanently delete all test bookings, payments, reviews, enquiries, and applications. Admin accounts and settings are safe. Continue?')">
          Erase Test Data
        </button>
      </form>
    </div>

  </div>

</div>

<script>
document.getElementById('captcha-type-select').addEventListener('change', function() {
  document.getElementById('captcha-keys').style.display = this.value === 'none' ? 'none' : 'block';
});
</script>
