<div class="form-section">
  <h3 class="form-section__title">General Settings</h3>
  <form method="POST" action="/admin/settings?_method=PUT">
    <input type="hidden" name="group" value="general">
    <div class="form-group"><label class="form-label">Site Name</label><input type="text" name="site_name" class="form-control" value="<%= settings.site_name || 'Caterus' %>"></div>
    <div class="form-group"><label class="form-label">Tagline</label><input type="text" name="site_tagline" class="form-control" value="<%= settings.site_tagline || '' %>"></div>
    <div class="form-row">
      <div class="form-group"><label class="form-label">Commission Rate (%)</label><input type="number" name="commission_rate" class="form-control" step="0.01" value="<%= settings.commission_rate || '12' %>"></div>
      <div class="form-group"><label class="form-label">GST Rate (%)</label><input type="number" name="gst_rate" class="form-control" step="0.01" value="<%= settings.gst_rate || '10' %>"></div>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
</div>
