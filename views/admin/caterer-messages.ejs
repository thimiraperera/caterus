<div class="page-header">
  <div>
    <h1 class="page-title">Caterer Messages</h1>
    <p style="color:var(--muted);font-size:0.88rem;margin-top:4px">Enquiries sent directly to a caterer from their profile page.</p>
  </div>
</div>

<div class="filter-bar" style="gap:10px;flex-wrap:wrap">
  <input type="text" id="cm-caterer" class="form-control" placeholder="Caterer..." style="flex:1;min-width:140px;max-width:200px" value="<%= caterer_search %>">
  <input type="text" id="cm-from"    class="form-control" placeholder="From (name or email)..." style="flex:1;min-width:160px;max-width:240px" value="<%= from_search %>">
  <select id="cm-status" class="form-control" style="max-width:160px">
    <option value="" <%=status===''?'selected':''%>>All statuses</option>
    <option value="new"    <%=status==='new'?'selected':''%>>New</option>
    <option value="read"   <%=status==='read'?'selected':''%>>Read</option>
    <option value="closed" <%=status==='closed'?'selected':''%>>Closed</option>
  </select>
  <select id="cm-per-page" class="form-control" style="max-width:120px">
    <option value="10" <%=per_page===10?'selected':''%>>10 / page</option>
    <option value="20" <%=per_page===20?'selected':''%>>20 / page</option>
    <option value="50" <%=per_page===50?'selected':''%>>50 / page</option>
  </select>
</div>

<div id="cm-table-wrap">
  <%- include('./caterer-messages/_table', { enquiries, page, totalPages, per_page, queryExtra, formatDate }) %>
</div>

<script>
(function() {
  var wrap = document.getElementById('cm-table-wrap');
  var dbt;
  var currentPerPage = String(<%= per_page %>);

  function getVal(id) { return document.getElementById(id).value; }

  function load(extra) {
    extra = extra || {};
    var params = new URLSearchParams();
    var cat = getVal('cm-caterer');
    var frm = getVal('cm-from');
    var st  = getVal('cm-status');
    if (cat) params.set('caterer_search', cat);
    if (frm) params.set('from_search', frm);
    if (st)  params.set('status', st);
    params.set('per_page', currentPerPage);
    if (extra.page) params.set('page', extra.page);
    wrap.classList.add('table-loading');
    fetch('/admin/caterer-messages?' + params.toString(), { headers: { 'X-Partial': '1' } })
      .then(function(r) { return r.text(); })
      .then(function(html) { wrap.innerHTML = html; wrap.classList.remove('table-loading'); })
      .catch(function() { wrap.classList.remove('table-loading'); });
    history.replaceState(null, '', '/admin/caterer-messages?' + params.toString());
  }

  function schedule() { clearTimeout(dbt); dbt = setTimeout(load, 300); }

  document.getElementById('cm-caterer').addEventListener('input', schedule);
  document.getElementById('cm-from').addEventListener('input', schedule);
  document.getElementById('cm-status').addEventListener('change', function() { load(); });
  document.getElementById('cm-per-page').addEventListener('change', function() {
    currentPerPage = this.value; load();
  });

  wrap.addEventListener('click', function(e) {
    var btn = e.target.closest('a.pg-btn');
    if (!btn) return;
    e.preventDefault();
    load({ page: new URL(btn.href).searchParams.get('page') });
  });
})();
</script>
