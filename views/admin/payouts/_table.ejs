<% if (payouts.length === 0) { %>
<div class="empty-state"><p>No payouts match your filters.</p></div>
<% } else { %>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead><tr><th>Caterer</th><th>Booking</th><th>Amount</th><th>Date</th><th>Status</th></tr></thead>
    <tbody>
      <% payouts.forEach(function(p) { %>
      <tr>
        <td><%= p.caterer_name || 'N/A' %></td>
        <td><%= p.booking_reference || '-' %></td>
        <td><strong><%= formatCurrency(p.amount) %></strong></td>
        <td><%= p.payout_date || '-' %></td>
        <td><span class="badge badge-<%= p.status %>"><%= p.status %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../../partials/pagination', { baseUrl: '/admin/payouts', page, totalPages, queryExtra }) %>
<% } %>
