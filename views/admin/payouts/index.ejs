<div class="stat-grid" style="margin-bottom:24px">
  <div class="stat-card"><div class="stat-card__label">Pending</div><div class="stat-card__value"><%= formatCurrency(stats.pendingTotal || 0) %></div></div>
  <div class="stat-card"><div class="stat-card__label">Completed</div><div class="stat-card__value"><%= formatCurrency(stats.completedTotal || 0) %></div></div>
  <div class="stat-card"><div class="stat-card__label">This Month</div><div class="stat-card__value"><%= formatCurrency(stats.monthlyTotal || 0) %></div></div>
</div>

<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;align-items:flex-end">
  <input type="text" id="pf-caterer" class="form-control" placeholder="Caterer..." style="flex:1;min-width:140px;max-width:200px" value="<%= pfCaterer %>">
  <input type="text" id="pf-booking" class="form-control" placeholder="Booking ref..." style="flex:1;min-width:130px;max-width:180px" value="<%= pfBooking %>">
  <div style="display:flex;flex-direction:column;gap:3px">
    <span style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--muted)">Date</span>
    <div style="display:flex;gap:6px;align-items:center">
      <input type="date" id="pf-date-from" class="form-control" style="min-width:130px" value="<%= pfDateFrom %>">
      <span style="color:var(--muted);font-size:0.8rem">to</span>
      <input type="date" id="pf-date-to" class="form-control" style="min-width:130px" value="<%= pfDateTo %>">
    </div>
  </div>
  <select id="pf-status" class="form-control" style="max-width:150px">
    <option value="" <%=currentStatus===''?'selected':''%>>All statuses</option>
    <option value="pending"   <%=currentStatus==='pending'?'selected':''%>>Pending</option>
    <option value="completed" <%=currentStatus==='completed'?'selected':''%>>Completed</option>
    <option value="cancelled" <%=currentStatus==='cancelled'?'selected':''%>>Cancelled</option>
  </select>
  <select id="pf-per-page" class="form-control" style="max-width:120px">
    <option value="10"  <%=per_page===10?'selected':''%>>10 / page</option>
    <option value="20"  <%=per_page===20?'selected':''%>>20 / page</option>
    <option value="50"  <%=per_page===50?'selected':''%>>50 / page</option>
    <option value="100" <%=per_page===100?'selected':''%>>100 / page</option>
  </select>
</div>

<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px">
  <div class="fsl" style="min-width:200px;max-width:340px;flex:1">
    <div class="fsl__hd">
      <span class="fsl__name">Amount ($)</span>
      <span class="fsl__val" id="pf-amount-label">Any</span>
    </div>
    <div class="fsl__track">
      <div class="fsl__fill" id="pf-amount-fill"></div>
      <input type="range" id="pf-amount-lo" min="0" max="20000" value="<%= pfAmountMin || 0 %>" step="50">
      <input type="range" id="pf-amount-hi" min="0" max="20000" value="<%= pfAmountMax || 20000 %>" step="50">
    </div>
  </div>
</div>

<div id="pf-table-wrap">
  <%- include('./_table', { payouts, page, totalPages, per_page, queryExtra, formatCurrency }) %>
</div>

<script>
(function() {
  var wrap = document.getElementById('pf-table-wrap');
  var dbt;
  var currentPerPage = String(<%= per_page %>);

  function getVal(id) { return document.getElementById(id).value; }

  function load(extra) {
    extra = extra || {};
    var params = new URLSearchParams();
    var c = getVal('pf-caterer'), b = getVal('pf-booking');
    var df = getVal('pf-date-from'), dt = getVal('pf-date-to');
    var st = getVal('pf-status');
    var alo = getVal('pf-amount-lo'), ahi = getVal('pf-amount-hi');
    if (c)  params.set('caterer_search', c);
    if (b)  params.set('booking_search', b);
    if (df) params.set('date_from', df);
    if (dt) params.set('date_to', dt);
    if (st) params.set('status', st);
    if (alo !== '0')     params.set('amount_min', alo);
    if (ahi !== '20000') params.set('amount_max', ahi);
    params.set('per_page', currentPerPage);
    if (extra.page) params.set('page', extra.page);
    wrap.classList.add('table-loading');
    fetch('/admin/payouts?' + params.toString(), { headers: { 'X-Partial': '1' } })
      .then(function(r) { return r.text(); })
      .then(function(html) { wrap.innerHTML = html; wrap.classList.remove('table-loading'); })
      .catch(function() { wrap.classList.remove('table-loading'); });
    history.replaceState(null, '', '/admin/payouts?' + params.toString());
  }

  function schedule() { clearTimeout(dbt); dbt = setTimeout(load, 320); }

  document.getElementById('pf-caterer').addEventListener('input', schedule);
  document.getElementById('pf-booking').addEventListener('input', schedule);
  document.getElementById('pf-date-from').addEventListener('change', function() { load(); });
  document.getElementById('pf-date-to').addEventListener('change', function() { load(); });
  document.getElementById('pf-status').addEventListener('change', function() { load(); });
  document.getElementById('pf-per-page').addEventListener('change', function() {
    currentPerPage = this.value; load();
  });

  wrap.addEventListener('click', function(e) {
    var btn = e.target.closest('a.pg-btn');
    if (!btn) return;
    e.preventDefault();
    load({ page: new URL(btn.href).searchParams.get('page') });
  });

  function bindSlider(loId, hiId, fillId, labelId, max, fmt) {
    var lo = document.getElementById(loId);
    var hi = document.getElementById(hiId);
    var fill = document.getElementById(fillId);
    var label = document.getElementById(labelId);
    function upd() {
      var lv = parseInt(lo.value), hv = parseInt(hi.value);
      var lp = lv / max * 100, hp = hv / max * 100;
      fill.style.left = lp + '%';
      fill.style.width = (hp - lp) + '%';
      label.textContent = (lv === 0 && hv === max) ? 'Any' : fmt(lv, hv);
    }
    lo.addEventListener('input', function() {
      if (parseInt(lo.value) > parseInt(hi.value)) lo.value = hi.value;
      upd(); schedule();
    });
    hi.addEventListener('input', function() {
      if (parseInt(hi.value) < parseInt(lo.value)) hi.value = lo.value;
      upd(); schedule();
    });
    upd();
  }

  bindSlider('pf-amount-lo', 'pf-amount-hi', 'pf-amount-fill', 'pf-amount-label', 20000, function(a, b) { return '$' + a.toLocaleString() + ' - $' + b.toLocaleString(); });
})();
</script>
