<div class="filter-bar" style="flex-wrap:wrap;gap:8px">
  <div class="filter-tabs" id="b-tabs">
    <a class="filter-tab<%= !currentStatus ? ' active' : '' %>" data-status="" href="/admin/bookings">All</a>
    <a class="filter-tab<%= currentStatus==='pending'   ? ' active' : '' %>" data-status="pending"   href="/admin/bookings?status=pending">Pending</a>
    <a class="filter-tab<%= currentStatus==='confirmed' ? ' active' : '' %>" data-status="confirmed" href="/admin/bookings?status=confirmed">Confirmed</a>
    <a class="filter-tab<%= currentStatus==='completed' ? ' active' : '' %>" data-status="completed" href="/admin/bookings?status=completed">Completed</a>
    <a class="filter-tab<%= currentStatus==='cancelled' ? ' active' : '' %>" data-status="cancelled" href="/admin/bookings?status=cancelled">Cancelled</a>
  </div>
  <select id="bf-per-page" class="form-control" style="max-width:120px;margin-left:auto">
    <option value="10"  <%=(per_page||20)===10?'selected':''%>>10 / page</option>
    <option value="20"  <%=(per_page||20)===20?'selected':''%>>20 / page</option>
    <option value="50"  <%=(per_page||20)===50?'selected':''%>>50 / page</option>
    <option value="100" <%=(per_page||20)===100?'selected':''%>>100 / page</option>
  </select>
</div>

<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;align-items:flex-end">
  <input type="text" id="bf-search"  class="form-control" placeholder="Ref, name, email..." style="flex:1;min-width:160px;max-width:220px" value="<%= bfSearch %>">
  <input type="text" id="bf-caterer" class="form-control" placeholder="Caterer..." style="flex:1;min-width:130px;max-width:180px" value="<%= bfCaterer %>">
  <div style="display:flex;flex-direction:column;gap:3px">
    <span style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--muted)">Date</span>
    <div style="display:flex;gap:6px;align-items:center">
      <input type="date" id="bf-date-from" class="form-control" style="min-width:130px" value="<%= bfDateFrom %>">
      <span style="color:var(--muted);font-size:0.8rem">to</span>
      <input type="date" id="bf-date-to" class="form-control" style="min-width:130px" value="<%= bfDateTo %>">
    </div>
  </div>
  <select id="bf-payment" class="form-control" style="max-width:150px">
    <option value="" <%=bfPayment===''?'selected':''%>>All payments</option>
    <option value="unpaid"   <%=bfPayment==='unpaid'?'selected':''%>>Unpaid</option>
    <option value="paid"     <%=bfPayment==='paid'?'selected':''%>>Paid</option>
    <option value="refunded" <%=bfPayment==='refunded'?'selected':''%>>Refunded</option>
  </select>
</div>

<div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:16px">
  <div class="fsl" style="min-width:200px;max-width:300px;flex:1">
    <div class="fsl__hd">
      <span class="fsl__name">Guests</span>
      <span class="fsl__val" id="bf-guest-label">Any</span>
    </div>
    <div class="fsl__track">
      <div class="fsl__fill" id="bf-guest-fill"></div>
      <input type="range" id="bf-guest-lo" min="0" max="500" value="<%= bfGuestMin || 0 %>" step="5">
      <input type="range" id="bf-guest-hi" min="0" max="500" value="<%= bfGuestMax || 500 %>" step="5">
    </div>
  </div>
  <div class="fsl" style="min-width:200px;max-width:300px;flex:1">
    <div class="fsl__hd">
      <span class="fsl__name">Total ($)</span>
      <span class="fsl__val" id="bf-total-label">Any</span>
    </div>
    <div class="fsl__track">
      <div class="fsl__fill" id="bf-total-fill"></div>
      <input type="range" id="bf-total-lo" min="0" max="50000" value="<%= bfTotalMin || 0 %>" step="100">
      <input type="range" id="bf-total-hi" min="0" max="50000" value="<%= bfTotalMax || 50000 %>" step="100">
    </div>
  </div>
</div>

<div id="b-table-wrap">
  <%- include('./_table', { bookings, page, totalPages, per_page: per_page||20, queryExtra, formatCurrency, formatDate }) %>
</div>

<script>
(function() {
  var wrap = document.getElementById('b-table-wrap');
  var dbt;
  var currentStatus = '<%= currentStatus %>';
  var currentPerPage = String(<%= per_page||20 %>);

  function getVal(id) { return document.getElementById(id).value; }

  function load(extra) {
    extra = extra || {};
    var params = new URLSearchParams();
    if (currentStatus)      params.set('status', currentStatus);
    var s = getVal('bf-search');
    var c = getVal('bf-caterer');
    var df = getVal('bf-date-from');
    var dt = getVal('bf-date-to');
    var pay = getVal('bf-payment');
    var glo = getVal('bf-guest-lo'), ghi = getVal('bf-guest-hi');
    var tlo = getVal('bf-total-lo'), thi = getVal('bf-total-hi');
    if (s)   params.set('search', s);
    if (c)   params.set('caterer_search', c);
    if (df)  params.set('date_from', df);
    if (dt)  params.set('date_to', dt);
    if (pay) params.set('payment_status', pay);
    if (glo !== '0')     params.set('guest_min', glo);
    if (ghi !== '500')   params.set('guest_max', ghi);
    if (tlo !== '0')     params.set('total_min', tlo);
    if (thi !== '50000') params.set('total_max', thi);
    params.set('per_page', currentPerPage);
    if (extra.page) params.set('page', extra.page);
    wrap.classList.add('table-loading');
    fetch('/admin/bookings?' + params.toString(), { headers: { 'X-Partial': '1' } })
      .then(function(r) { return r.text(); })
      .then(function(html) { wrap.innerHTML = html; wrap.classList.remove('table-loading'); })
      .catch(function() { wrap.classList.remove('table-loading'); });
    history.replaceState(null, '', '/admin/bookings?' + params.toString());
  }

  function schedule() { clearTimeout(dbt); dbt = setTimeout(load, 320); }

  document.getElementById('bf-search').addEventListener('input', schedule);
  document.getElementById('bf-caterer').addEventListener('input', schedule);
  document.getElementById('bf-date-from').addEventListener('change', function() { load(); });
  document.getElementById('bf-date-to').addEventListener('change', function() { load(); });
  document.getElementById('bf-payment').addEventListener('change', function() { load(); });
  document.getElementById('bf-per-page').addEventListener('change', function() {
    currentPerPage = this.value; load();
  });

  document.querySelectorAll('#b-tabs .filter-tab').forEach(function(tab) {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      currentStatus = this.dataset.status || '';
      document.querySelectorAll('#b-tabs .filter-tab').forEach(function(t) { t.classList.remove('active'); });
      this.classList.add('active');
      load();
    });
  });

  wrap.addEventListener('click', function(e) {
    var btn = e.target.closest('a.pg-btn');
    if (!btn) return;
    e.preventDefault();
    load({ page: new URL(btn.href).searchParams.get('page') });
  });

  function bindSlider(loId, hiId, fillId, labelId, max, fmt) {
    var lo = document.getElementById(loId);
    var hi = document.getElementById(hiId);
    var fill = document.getElementById(fillId);
    var label = document.getElementById(labelId);
    function upd() {
      var lv = parseInt(lo.value), hv = parseInt(hi.value);
      var lp = lv / max * 100, hp = hv / max * 100;
      fill.style.left = lp + '%';
      fill.style.width = (hp - lp) + '%';
      label.textContent = (lv === 0 && hv === max) ? 'Any' : fmt(lv, hv);
    }
    lo.addEventListener('input', function() {
      if (parseInt(lo.value) > parseInt(hi.value)) lo.value = hi.value;
      upd(); schedule();
    });
    hi.addEventListener('input', function() {
      if (parseInt(hi.value) < parseInt(lo.value)) hi.value = lo.value;
      upd(); schedule();
    });
    upd();
  }

  bindSlider('bf-guest-lo', 'bf-guest-hi', 'bf-guest-fill', 'bf-guest-label', 500, function(a, b) { return a + ' - ' + b + ' guests'; });
  bindSlider('bf-total-lo', 'bf-total-hi', 'bf-total-fill', 'bf-total-label', 50000, function(a, b) { return '$' + a.toLocaleString() + ' - $' + b.toLocaleString(); });
})();
</script>
