<div class="filter-bar">
  <div class="filter-tabs">
    <a href="/admin/bookings" class="filter-tab<%= !bookings.length || true ? ' active' : '' %>">All</a>
    <a href="/admin/bookings?status=pending" class="filter-tab">Pending</a>
    <a href="/admin/bookings?status=confirmed" class="filter-tab">Confirmed</a>
    <a href="/admin/bookings?status=completed" class="filter-tab">Completed</a>
    <a href="/admin/bookings?status=cancelled" class="filter-tab">Cancelled</a>
  </div>
  <form method="GET" action="/admin/bookings" style="flex:1;max-width:300px">
    <input type="text" name="search" class="form-control" placeholder="Search ref, name, email…">
  </form>
</div>

<% if (bookings.length === 0) { %>
<div class="empty-state"><p>No bookings found.</p></div>
<% } else { %>
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead><tr><th>Reference</th><th>Customer</th><th>Caterer</th><th>Event Date</th><th>Guests</th><th>Total</th><th>Status</th><th>Payment</th></tr></thead>
    <tbody>
      <% bookings.forEach(b => { %>
      <tr onclick="window.location='/admin/bookings/<%= b.id %>'" style="cursor:pointer">
        <td><strong><%= b.reference %></strong></td>
        <td><%= b.customer_first_name %> <%= b.customer_last_name || '' %></td>
        <td><%= b.caterer_name || 'N/A' %></td>
        <td><%= formatDate(b.event_date) %></td>
        <td><%= b.guest_count %></td>
        <td><strong><%= formatCurrency(b.total) %></strong></td>
        <td><span class="badge badge-<%= b.status %>"><%= b.status %></span></td>
        <td><span class="badge badge-<%= b.payment_status %>"><%= b.payment_status %></span></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../../partials/pagination', { baseUrl: '/admin/bookings', page, totalPages }) %>
<% } %>
