<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div></div>
  <div style="display:flex;gap:10px">
    <% if (faqs.length === 0) { %>
    <form method="POST" action="/admin/faqs/seed">
      <button type="submit" class="btn btn-secondary">Seed defaults</button>
    </form>
    <% } %>
    <a href="/admin/faqs/create" class="btn btn-primary" style="display:inline-flex;align-items:center;gap:8px">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New FAQ
    </a>
  </div>
</div>

<% if (faqs.length === 0) { %>
<div class="form-section" style="border-left:3px solid var(--accent);background:var(--accent-soft)">
  <p style="font-size:0.9rem;color:var(--ink-soft);margin:0">
    <strong>No custom FAQs yet.</strong> The homepage shows the 6 built-in defaults.
    Add at least one FAQ here to switch to your custom set, or click <strong>Seed defaults</strong> to import them for editing.
  </p>
</div>
<% } else { %>

<div id="faq-save-banner" style="display:none;margin-bottom:12px">
  <div style="display:flex;align-items:center;gap:12px;padding:10px 16px;background:var(--accent-soft);border:1px solid var(--accent);border-radius:var(--radius-sm);font-size:0.88rem">
    <span id="faq-save-status" style="flex:1;color:var(--ink-soft)">Order changed</span>
    <span id="faq-save-spinner" style="display:none;color:var(--muted)">Saving...</span>
    <span id="faq-save-ok" style="display:none;color:var(--accent);font-weight:600">Saved</span>
  </div>
</div>

<div class="admin-table-wrap">
  <table class="admin-table" id="faq-table">
    <thead>
      <tr>
        <th style="width:36px"></th>
        <th>Question</th>
        <th style="width:110px">Status</th>
        <th style="width:120px">Actions</th>
      </tr>
    </thead>
    <tbody id="faq-tbody">
      <% faqs.forEach(f => { %>
      <tr class="faq-row" data-id="<%= f.id %>" draggable="true">
        <td class="drag-handle" title="Drag to reorder">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;margin:auto;opacity:0.4;cursor:grab"><circle cx="9" cy="5" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="5" r="1" fill="currentColor" stroke="none"/><circle cx="9" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="9" cy="19" r="1" fill="currentColor" stroke="none"/><circle cx="15" cy="19" r="1" fill="currentColor" stroke="none"/></svg>
        </td>
        <td><strong><%= f.question %></strong></td>
        <td>
          <% if (f.is_published) { %>
            <span class="badge badge-confirmed">Published</span>
          <% } else { %>
            <span class="badge badge-cancelled">Hidden</span>
          <% } %>
        </td>
        <td>
          <div style="display:flex;gap:8px;align-items:center">
            <a href="/admin/faqs/<%= f.id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
            <form method="POST" action="/admin/faqs/<%= f.id %>?_method=DELETE" onsubmit="return confirm('Delete this FAQ?')">
              <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<p style="margin-top:12px;font-size:0.82rem;color:var(--muted)">Drag rows to reorder. The JSON-LD FAQ schema is injected automatically when at least one FAQ is published.</p>

<style>
.faq-row { transition: background 0.15s; }
.faq-row.drag-over { background: var(--accent-soft); outline: 2px dashed var(--accent); outline-offset: -2px; }
.faq-row.dragging { opacity: 0.4; }
.drag-handle { cursor: grab; user-select: none; }
.drag-handle:active { cursor: grabbing; }
</style>

<script>
(function() {
  const tbody = document.getElementById('faq-tbody');
  const banner = document.getElementById('faq-save-banner');
  const statusEl = document.getElementById('faq-save-status');
  const spinnerEl = document.getElementById('faq-save-spinner');
  const okEl = document.getElementById('faq-save-ok');
  let dragSrc = null;
  let saveTimer = null;

  function getOrder() {
    return Array.from(tbody.querySelectorAll('.faq-row')).map(r => r.dataset.id);
  }

  async function saveOrder() {
    spinnerEl.style.display = 'inline';
    statusEl.style.display = 'none';
    okEl.style.display = 'none';
    try {
      const res = await fetch('/admin/faqs/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ order: getOrder() }),
      });
      if (!res.ok) throw new Error('Failed');
      spinnerEl.style.display = 'none';
      okEl.style.display = 'inline';
      setTimeout(() => { banner.style.display = 'none'; }, 2000);
    } catch (e) {
      spinnerEl.style.display = 'none';
      statusEl.textContent = 'Save failed. Try again.';
      statusEl.style.display = 'inline';
      statusEl.style.color = '#dc3545';
    }
  }

  tbody.addEventListener('dragstart', e => {
    dragSrc = e.target.closest('.faq-row');
    if (!dragSrc) return;
    dragSrc.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', dragSrc.dataset.id);
  });

  tbody.addEventListener('dragend', e => {
    document.querySelectorAll('.faq-row').forEach(r => r.classList.remove('dragging', 'drag-over'));
    dragSrc = null;
  });

  tbody.addEventListener('dragover', e => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    const target = e.target.closest('.faq-row');
    if (!target || target === dragSrc) return;
    document.querySelectorAll('.faq-row').forEach(r => r.classList.remove('drag-over'));
    target.classList.add('drag-over');
  });

  tbody.addEventListener('dragleave', e => {
    const target = e.target.closest('.faq-row');
    if (target) target.classList.remove('drag-over');
  });

  tbody.addEventListener('drop', e => {
    e.preventDefault();
    const target = e.target.closest('.faq-row');
    if (!target || target === dragSrc || !dragSrc) return;
    target.classList.remove('drag-over');

    const rows = Array.from(tbody.querySelectorAll('.faq-row'));
    const srcIdx = rows.indexOf(dragSrc);
    const tgtIdx = rows.indexOf(target);
    if (tgtIdx > srcIdx) {
      target.after(dragSrc);
    } else {
      target.before(dragSrc);
    }

    banner.style.display = 'block';
    statusEl.textContent = 'Order changed';
    statusEl.style.color = '';
    statusEl.style.display = 'inline';
    spinnerEl.style.display = 'none';
    okEl.style.display = 'none';

    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveOrder, 600);
  });
})();
</script>

<% } %>
