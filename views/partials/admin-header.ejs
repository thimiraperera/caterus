<header class="admin-topbar">
  <h1 class="topbar-title"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
  <div class="topbar-right">
    <a href="/" class="topbar-link" target="_blank" rel="noopener">
      View Site
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
    <% if (admin) { %>
    <div class="topbar-avatar-wrap" id="topbar-avatar-wrap">
      <div class="topbar-avatar" id="topbar-avatar-btn" aria-label="Account menu">
        <% if (admin.profile_image) { %>
          <img src="/<%= admin.profile_image %>" alt="Profile">
        <% } else { %>
          <%= admin.name ? admin.name.charAt(0).toUpperCase() : 'A' %>
        <% } %>
      </div>
      <div class="topbar-dropdown" id="topbar-dropdown">
        <div class="topbar-dropdown-header">
          <strong><%= admin.name || 'Admin' %></strong>
          <span><%= admin.email || '' %></span>
        </div>
        <a href="/admin/settings/profile" class="topbar-dropdown-item">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile Settings
        </a>
        <div class="topbar-dropdown-divider"></div>
        <div class="theme-toggle-row">
          <span>Theme</span>
          <div class="theme-toggle-switch">
            <button class="theme-btn" id="theme-light-btn" onclick="setTheme('light')">Light</button>
            <button class="theme-btn" id="theme-dark-btn" onclick="setTheme('dark')">Dark</button>
          </div>
        </div>
        <div class="topbar-dropdown-divider"></div>
        <a href="/admin/logout" class="topbar-dropdown-item danger">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </a>
      </div>
    </div>
    <% } %>
  </div>
</header>

<script>
(function() {
  var wrap = document.getElementById('topbar-avatar-wrap');
  var btn  = document.getElementById('topbar-avatar-btn');
  if (!wrap || !btn) return;

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    wrap.classList.toggle('open');
  });
  document.addEventListener('click', function(e) {
    if (!wrap.contains(e.target)) wrap.classList.remove('open');
  });

  function syncThemeBtns() {
    var t = localStorage.getItem('adminTheme') || 'light';
    document.getElementById('theme-light-btn').classList.toggle('active', t === 'light');
    document.getElementById('theme-dark-btn').classList.toggle('active', t === 'dark');
  }
  syncThemeBtns();

  window.setTheme = function(t) {
    localStorage.setItem('adminTheme', t);
    document.documentElement.setAttribute('data-theme', t);
    syncThemeBtns();
  };
})();
</script>
