<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<%
  const _qe = (typeof queryExtra !== 'undefined' && queryExtra) ? '&' + queryExtra : '';
  function pgUrl(p) { return baseUrl + '?page=' + p + _qe; }
%>
<div class="pagination">
  <% if (page > 1) { %>
    <a href="<%= pgUrl(page - 1) %>" class="pg-btn">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Prev
    </a>
  <% } %>
  <%
    let _prev = null;
    for (let _i = 1; _i <= totalPages; _i++) {
      const _show = _i === 1 || _i === totalPages || Math.abs(_i - page) <= 2;
      if (!_show) continue;
      if (_prev !== null && _i - _prev > 1) {
  %><span class="pg-dots">...</span><%
      }
      _prev = _i;
      if (_i === page) {
  %><span class="pg-btn pg-active"><%= _i %></span><%
      } else {
  %><a href="<%= pgUrl(_i) %>" class="pg-btn"><%= _i %></a><%
      }
    }
  %>
  <% if (page < totalPages) { %>
    <a href="<%= pgUrl(page + 1) %>" class="pg-btn">
      Next
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </a>
  <% } %>
</div>
<% } %>
