<% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
<div class="pagination">
  <% if (page > 1) { %>
    <a href="<%= baseUrl %>?page=<%= page - 1 %>" class="pg-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg> Prev</a>
  <% } %>
  <% for (let i = 1; i <= totalPages; i++) { %>
    <% if (i === page) { %>
      <span class="pg-btn pg-active"><%= i %></span>
    <% } else if (Math.abs(i - page) <= 2 || i === 1 || i === totalPages) { %>
      <a href="<%= baseUrl %>?page=<%= i %>" class="pg-btn"><%= i %></a>
    <% } else if (Math.abs(i - page) === 3) { %>
      <span class="pg-dots">…</span>
    <% } %>
  <% } %>
  <% if (page < totalPages) { %>
    <a href="<%= baseUrl %>?page=<%= page + 1 %>" class="pg-btn">Next <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></a>
  <% } %>
</div>
<% } %>
