<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Page Not Found — Caterus</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <style>
    .notfound { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 40px 20px; }
    .notfound h1 { font-size: 6rem; font-weight: 800; color: var(--sage, #75896d); margin: 0; line-height: 1; }
    .notfound p { font-size: 1.1rem; color: #57544c; margin: 12px 0 24px; max-width: 400px; }
    .notfound a { display: inline-flex; align-items: center; gap: 6px; padding: 12px 28px; background: #75896d; color: #fff; border-radius: 100px; font-weight: 600; text-decoration: none; transition: background 0.3s; }
    .notfound a:hover { background: #63745c; }
  </style>
</head>
<body>
  <div class="notfound">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href="/">← Back to Caterus</a>
  </div>
</body>
</html>
