{
  "name": "caterus",
  "version": "1.0.0",
  "description": "Caterus - Australia's catering marketplace",
  "main": "server.cjs",
  "scripts": {
    "start": "node server.cjs",
    "dev": "nodemon server.cjs",
    "db:create": "mysql -u root < database/schema.sql",
    "db:seed": "mysql -u root caterus < database/seed.sql",
    "db:reset": "mysql -u root < database/schema.sql && mysql -u root caterus < database/seed.sql"
  },
  "keywords": ["catering", "marketplace", "australia", "melbourne"],
  "author": "Caterus Pty Ltd",
  "license": "PROPRIETARY",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.0",
    "express-validator": "^7.2.0",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.14",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "stripe": "^16.8.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
